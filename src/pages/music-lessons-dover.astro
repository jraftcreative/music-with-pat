---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "What instruments are available for children near Dover?",
    answer: "Patricia offers piano and violin lessons along with broader musicianship training that covers music theory, ear training, and rhythm skills. Children can pursue one instrument or explore both before deciding. All lessons are private and one-to-one, shaped around each child's interests and pace."
  },
  {
    question: "How do I get to Patricia's studio from Dover?",
    answer: "The drive from Dover to Patricia's Tengah studio takes about 20 minutes. Dover MRT (EW22) on the East-West Line connects into the broader network, and the AYE provides a direct route for drivers. Some Dover families combine lessons with other activities along the way."
  },
  {
    question: "Are home-based music lessons available in Dover?",
    answer: "Yes. Patricia makes house visits across Dover, including the HDB estates and private housing near ACS and SIT. Home lessons maintain the same quality and structure as studio sessions. Get in touch with Patricia for house visit scheduling and pricing."
  },
  {
    question: "From what age does Patricia accept music students?",
    answer: "Patricia teaches children from age four onwards. She has found that most four-year-olds have sufficient hand coordination and focus for structured music learning. Every new student begins with a free consultation where Patricia assesses readiness and discusses goals with parents."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="Music Lessons for Children in Dover | Music with Pat"
  description="Music lessons for children in Dover, Singapore. Piano, violin, and general musicianship near ACS and SIT with experienced, child-centred teaching. Ages 4 and up."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Music Lessons",
      "name": "Music Lessons for Children in Dover",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Dover, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "Patient, child-centred music lessons for children in Dover, Singapore. Piano, violin, and general musicianship with ABRSM preparation available."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'Music Lessons Dover' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">Dover & Tengah</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          Music Lessons for Children in Dover
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          Dover is an education-rich area, home to institutions like ACS and SIT, and filled with families who value structured, meaningful enrichment. Patricia's studio in Tengah brings that same standard to music education, offering piano, violin, and comprehensive musicianship training in private, one-on-one sessions designed to develop the whole musician in every child.
        </p>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-piano-lessons.webp"
              alt="Patricia - Music Teacher for Children near Dover"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              Patricia has more than ten years of experience teaching music to children. Her studio in Tengah is accessible from Dover via the AYE, and she regularly works with families from the Dover and Clementi corridor.
            </p>
            <p class="text-base-600 mb-4">
              What sets her apart is the integration of music training with early childhood expertise. Her Bachelor's degree in Early Childhood Education and Music Education means she approaches teaching with a deep understanding of child development, not just musical technique. She knows when to push and when to pull back, and she reads each child with care.
            </p>
            <p class="text-base-600 mb-6">
              Patricia teaches piano and violin and welcomes children who want to try both before specialising. She prepares students for ABRSM exams in both instruments and is equally committed to those who prefer to learn without formal grading. Her teaching is thoughtful, patient, and always calibrated to the individual child.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Preparation</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Ages 4+</span>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Why Families Choose Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why Families Trust Patricia</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Families from Dover Choose Patricia
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Multi-Instrument Teaching</h3>
                <p class="text-base-600 text-sm">Patricia teaches both piano and violin and weaves music theory, ear training, and rhythm into every session. Children build a complete musical foundation instead of learning isolated technique on one instrument. For Dover families with academically driven children, this holistic approach aligns well with how they already think about education.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Education Background</h3>
                <p class="text-base-600 text-sm">Patricia holds a B.Ed in Early Childhood Education with Music Education. This dual qualification means she brings genuine expertise in how children develop, learn, and process new information. She does not just know music; she knows children, and that distinction shapes every lesson she teaches.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Structured or Flexible Learning</h3>
                <p class="text-base-600 text-sm">Patricia offers both ABRSM exam preparation and a more exploratory, non-exam pathway. Dover families often lean toward structured learning, and Patricia can match that preference with disciplined exam preparation. But she is equally comfortable guiding children who want to learn music for its own sake, without the pressure of formal assessment.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Undivided Attention</h3>
                <p class="text-base-600 text-sm">Patricia teaches from a private home studio in Tengah. There are no back-to-back students in adjacent rooms, no lobby noise, and no distractions. Your child has Patricia's complete attention for the entire lesson. This personal setting is a key reason Dover families choose her over the commercial music schools that are plentiful in the area.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from Dover -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Easy to Reach</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from Dover
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              Dover is approximately 20 minutes from Patricia's Tengah studio by car, with the AYE providing a direct westbound route. Traffic is generally manageable outside of peak school drop-off and pick-up hours.
            </p>
            <p class="text-base-600 mb-4">
              Dover MRT station (EW22) on the East-West Line connects to Jurong East interchange, from where Tengah is accessible. Families who drive from Dover often pair lessons with errands in Clementi or Jurong East, making the outing efficient.
            </p>
            <p class="text-base-600">
              Patricia also offers house visits in the Dover area, including the housing estates near ACS and along Commonwealth Avenue West. This option works well for families with tight after-school schedules.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By car:</strong> Around 20 minutes via the AYE heading west</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By MRT:</strong> East-West Line from Dover (EW22) towards Jurong East and Tengah</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By bus:</strong> Services along Commonwealth Avenue West and Dover Road</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">House visits:</strong> Available across Dover, including estates near ACS and SIT</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- What Lessons Look Like -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Lesson Structure</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What Lessons Look Like
          </h2>
        </div>

        <div class="space-y-4 text-base-600">
          <p>
            Sessions are private and one-to-one, running between 45 and 60 minutes based on the child's age and level of experience. For new beginners, Patricia starts with shorter sessions and builds up gradually as concentration and comfort grow.
          </p>
          <p>
            A typical lesson weaves together hands-on playing — piano or violin — with music theory, aural training, and rhythm work. Patricia moves between activities with clear intention, keeping children engaged while ensuring each session contributes to visible, measurable progress. Sight-reading and technical exercises develop naturally as part of the lesson flow.
          </p>
          <p>
            The lesson experience is the same whether your child visits the Tengah studio or Patricia comes to your Dover home: attentive, purposeful, and carefully adapted to your child's personality and learning needs.
          </p>
        </div>

        <div class="text-center mt-8">
          <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            View Full Lesson Details
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in Dover:
          <a href="/piano-lessons-dover/" class="text-primary-600 hover:underline">Piano Lessons</a> ·
          <a href="/violin-lessons-dover/" class="text-primary-600 hover:underline">Violin Lessons</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/music-lessons-buona-vista/" class="text-primary-600 hover:underline">Buona Vista</a>,
          <a href="/music-lessons-clementi/" class="text-primary-600 hover:underline">Clementi</a>, and
          <a href="/music-lessons-holland-village/" class="text-primary-600 hover:underline">Holland Village</a>.
          <a href="/lessons/" class="text-primary-600 hover:underline">View all lesson details</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Start Your Child's Musical Journey
        </h2>
        <p class="text-base-600 mb-6">Get in touch with Patricia for a free consultation to discuss your child's interests and what lessons could look like. No commitment needed.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20interested%20in%20music%20lessons%20for%20my%20child%20in%20Dover."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>
