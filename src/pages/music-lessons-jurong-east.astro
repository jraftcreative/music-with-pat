---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "How close is the studio to Jurong East?",
    answer: "Patricia's Tengah studio is roughly 10 minutes from Jurong East by car — one of the shortest drives of any area she serves. The route is entirely local, making it a quick and easy weekly commitment."
  },
  {
    question: "What instruments does Patricia teach?",
    answer: "Patricia teaches piano, violin, and general musicianship. If your child is unsure which instrument to pursue, musicianship sessions build foundational skills — rhythm, listening, pitch — that apply to any instrument. A free consultation is available to discuss the best starting point."
  },
  {
    question: "Can Patricia visit homes in Jurong East?",
    answer: "Yes, house visits are available throughout Jurong East, including the HDB estates, condominiums, and residential areas across the town. House visit rates differ slightly from studio sessions — reach out for details."
  },
  {
    question: "Is my child too young for lessons?",
    answer: "If your child is four or older, they are welcome to start. Patricia's training in early childhood education means she is experienced with very young learners. She uses short, playful activities to introduce musical concepts at a pace that feels natural for each child."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="Music Lessons for Children in Jurong East | Music with Pat"
  description="Music lessons for children in Jurong East, Singapore. Piano, violin, and musicianship from an experienced educator. Studio in Tengah with house visits available. Ages 4 and up."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Music Lessons",
      "name": "Music Lessons for Children in Jurong East",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Jurong East, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "Piano, violin, and musicianship lessons for children in Jurong East, Singapore. Thoughtful teaching in a calm studio environment in nearby Tengah."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'Music Lessons Jurong East' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">Jurong East & Tengah</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          Music Lessons for Children in Jurong East
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          Jurong East is the commercial heart of Singapore's west — anchored by JCube, Westgate, and the JEM mall cluster. But beyond the retail corridor, the town has a strong residential community with established HDB estates and a family-friendly atmosphere. Patricia's studio in Tengah is just 10 minutes away, making it one of the most convenient options for music education in the area. She teaches piano, violin, and musicianship with the kind of care and expertise that busy Jurong East families can rely on.
        </p>
      </div>
    </section>

    <!-- Why Families from Jurong East Choose Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why Families Trust Patricia</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Families from Jurong East Choose Patricia
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Music Lessons Minutes Away</h3>
                <p class="text-base-600 text-sm">Tengah is effectively next door to Jurong East — around 10 minutes by car. This proximity removes the commute barrier that often makes weekly lessons difficult to sustain. Your child can get high-quality music instruction without a long journey before or after.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Child Development at the Core</h3>
                <p class="text-base-600 text-sm">Patricia's Bachelor's degree in Early Childhood Education with Music Education means her teaching is built on proper understanding of how children learn. She adapts her methods to each child's stage and temperament, creating lessons that feel natural and engaging.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">No-Pressure Exam Philosophy</h3>
                <p class="text-base-600 text-sm">ABRSM exam preparation is available for students who respond well to clear goals. Patricia never assumes exams are the right path — she discusses your child's personality and progress with you, then recommends the approach that will genuinely serve their musical development.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Quiet Studio, Personal Attention</h3>
                <p class="text-base-600 text-sm">Patricia's home studio in Tengah offers something the busy Jurong East malls cannot — a quiet, private learning environment. No commercial noise, no waiting rooms. Just focused, personal attention for your child in a space designed for learning.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from Jurong East -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Easy to Reach</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from Jurong East
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              From Jurong East, the drive to Patricia's Tengah studio takes approximately 10 minutes. The route is local and direct, avoiding expressways entirely. This makes it one of the quickest journeys of any neighbourhood she serves.
            </p>
            <p class="text-base-600 mb-4">
              Families often head to the studio straight after school or before weekend shopping. The close proximity to Jurong East's retail and dining options means you can easily combine errands with your child's lesson.
            </p>
            <p class="text-base-600">
              Patricia also offers house visits throughout Jurong East. Whether you live near JCube, along Jurong East Street, or in the surrounding HDB blocks, she can bring lessons to your home.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By car:</strong> Around 10 minutes via local roads</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By MRT:</strong> Jurong Region Line from Jurong East towards Tengah (or North-South/East-West Line to Jurong East, then transfer)</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By bus:</strong> Local bus services connect Jurong East to the Tengah area</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">House visits:</strong> Available across Jurong East, including all residential estates</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- What Lessons Look Like -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Lesson Structure</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What Lessons Look Like
          </h2>
        </div>

        <div class="space-y-4 text-base-600">
          <p>
            Every lesson is a private, one-to-one session lasting 45 to 60 minutes. Younger beginners start shorter and build up. Jurong East families appreciate this practical flexibility — it makes lessons work for children with varying attention spans and energy levels.
          </p>
          <p>
            Whether the focus is piano, violin, or general musicianship, each session integrates practical playing with listening skills, rhythm exercises, and theory. Patricia keeps lessons dynamic and purposeful, building real musical ability while keeping the experience enjoyable.
          </p>
          <p>
            The lesson experience is the same whether your child visits the Tengah studio or Patricia comes to your Jurong East home. Teaching is always personal and consistent.
          </p>
        </div>

        <div class="text-center mt-8">
          <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            View Full Lesson Details
          </a>
        </div>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-piano-lessons.webp"
              alt="Patricia - Music Teacher for Children near Jurong East"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              Patricia has been teaching music to children for over a decade. Based in Tengah, she is particularly convenient for Jurong East families — the studio is just minutes away. She teaches piano, violin, and musicianship with a focus on genuine, individualised instruction.
            </p>
            <p class="text-base-600 mb-4">
              Her Bachelor's degree in Early Childhood Education with Music Education gives her teaching a depth that goes beyond playing technique. She knows how children develop and uses that understanding to create lessons that are both effective and enjoyable.
            </p>
            <p class="text-base-600 mb-6">
              Patricia is warm and reliable. She builds strong relationships with her students, keeps parents informed about progress, and maintains clear expectations. Whether your child is just starting or has been learning for years, she provides the same dedicated attention.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Preparation</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Ages 4+</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in Jurong East:
          <a href="/piano-lessons-jurong-east/" class="text-primary-600 hover:underline">Piano Lessons</a> ·
          <a href="/violin-lessons-jurong-east/" class="text-primary-600 hover:underline">Violin Lessons</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/music-lessons-chinese-garden/" class="text-primary-600 hover:underline">Chinese Garden</a>,
          <a href="/music-lessons-clementi/" class="text-primary-600 hover:underline">Clementi</a>, and
          <a href="/music-lessons-bukit-batok/" class="text-primary-600 hover:underline">Bukit Batok</a>.
          <a href="/lessons/" class="text-primary-600 hover:underline">View all lesson details</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Start Your Child's Musical Journey
        </h2>
        <p class="text-base-600 mb-6">Get in touch with Patricia for a free consultation to discuss your child's interests and what lessons could look like. No commitment needed.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20interested%20in%20music%20lessons%20for%20my%20child%20in%20Jurong%20East."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>