---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "What should we expect at the first violin lesson?",
    answer: "The first session is as much a getting-to-know-you meeting as it is a lesson. Patricia introduces the violin to your child in a relaxed, low-pressure way — letting them hold the instrument, feel the weight of the bow, and hear what an open string sounds like when properly drawn. She assesses your child's hand size, attention span, and general readiness, then discusses with you what a lesson plan might look like going forward. There is no obligation after this initial session."
  },
  {
    question: "How far is it from Alexandra to Patricia's studio in Tengah?",
    answer: "From the Alexandra area, the drive to Tengah takes approximately 20 minutes via the AYE. Join the expressway at the Alexandra Road entrance — which is close to IKEA Alexandra and Queensway Shopping Centre — and head west towards Jurong. The route is direct and traffic is generally manageable outside peak hours. Patricia also offers house visits throughout the Alexandra district."
  },
  {
    question: "How does Patricia handle a child who wants to give up?",
    answer: "Moments of frustration are normal in violin learning, especially when a new technique feels physically awkward. Patricia addresses these moments by adjusting the difficulty level, revisiting pieces the child already plays well to rebuild confidence, and having honest conversations about what is hard and why. Her early childhood training helps her distinguish between genuine disinterest and temporary frustration, so she can respond appropriately rather than simply pushing through."
  },
  {
    question: "Can adults take violin lessons with Patricia too?",
    answer: "Yes, Patricia teaches adult beginners and returning players as well. While her primary focus is children aged four and above, she welcomes adults who want to learn violin or return to the instrument after a break. Adult lessons are structured differently — with more emphasis on self-directed practice and musical goals that suit each individual's lifestyle and interests."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="Violin Lessons for Children in Alexandra | Music with Pat"
  description="Violin lessons for children in Alexandra, Singapore. Dedicated, child-centred teaching with fractional-size violins, ABRSM preparation, and careful technique building from the start. Ages 4 and up."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Violin Lessons",
      "name": "Violin Lessons for Children in Alexandra",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Alexandra, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "Dedicated, child-centred violin lessons for children in Alexandra, Singapore. ABRSM violin preparation, fractional-size instruments, and a calm studio environment in nearby Tengah."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'Violin Lessons Alexandra' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">Alexandra & Tengah</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          Violin Lessons for Children in Alexandra
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          The Alexandra area straddles the border between Singapore's central and western regions, anchored by familiar landmarks like Queensway Shopping Centre, IKEA Alexandra, and the Alexandra Retail Centre. Families in the surrounding HDB estates and condominiums along Alexandra Road and Queensway enjoy excellent connectivity, with the AYE providing a direct route to Patricia's violin studio in Tengah — a drive of roughly 20 minutes. Her quiet, private teaching space offers Alexandra children a focused environment to develop proper violin technique, musicianship, and the discipline that comes with learning a demanding instrument well.
        </p>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-violin-lessons.webp"
              alt="Patricia teaching a young violin student near Alexandra Singapore"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              Over more than a decade of teaching, Patricia has developed a clear and effective approach to violin instruction for children. She believes that the first months of learning an instrument set the trajectory for everything that follows — which is why she is meticulous about posture, bow hold, and tone production from the very beginning, rather than rushing ahead to pieces before the foundations are secure.
            </p>
            <p class="text-base-600 mb-4">
              Patricia's Bachelor's degree in Early Childhood Education with Music Education means she sees violin teaching through the lens of child development. She recognises that a young child's ability to coordinate both hands simultaneously develops gradually, that concentration spans vary significantly between ages four and eight, and that the emotional experience of learning something difficult matters as much as the technical outcome. This awareness informs every lesson she gives.
            </p>
            <p class="text-base-600 mb-6">
              Her studio in Tengah is a purposeful space — private, quiet, and free from the distractions that come with shared teaching environments. Alexandra families who visit find a place where their child can settle in and focus, supported by a teacher who genuinely cares about getting the details right.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Preparation</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Ages 4+</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Families from Alexandra Choose Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why Families Choose Patricia</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Families from Alexandra Choose Patricia
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Foundations First, Always</h3>
                <p class="text-base-600 text-sm">Patricia invests heavily in getting the basics right. She spends as long as needed on bow hold, posture, and open string tone production before moving to fingered notes and simple melodies. Alexandra families appreciate this thoroughness because it means their child avoids the bad habits that are difficult and demoralising to correct later. Every skill is built on something solid.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Trained to Teach Young Children</h3>
                <p class="text-base-600 text-sm">Not every violinist can teach a four-year-old effectively. Patricia's degree in Early Childhood Education gives her specialised knowledge that pure music qualifications do not cover — understanding of motor development stages, age-appropriate communication, attention management, and the emotional scaffolding that young children need when learning something physically demanding. She applies this knowledge in every lesson.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Reliable ABRSM Results</h3>
                <p class="text-base-600 text-sm">Patricia has a strong track record with ABRSM violin examinations. She prepares students comprehensively, working through scales, set pieces, sight-reading, and aural tests as an integrated part of regular lessons rather than as a frantic final push. Her students sit exams feeling confident and well-prepared, which shows in their results — and more importantly, in their continued enthusiasm for playing.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">A Space That Serves the Instrument</h3>
                <p class="text-base-600 text-sm">Violin is an instrument that rewards careful listening, and Patricia's private studio in Tengah provides the quiet needed for that listening to develop. Your child can hear the resonance of a well-placed note, notice the difference between a smooth and a scratchy bow stroke, and begin developing the tonal sensitivity that will serve them through every grade and beyond. No enrichment centre or community room can replicate this acoustic clarity.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from Alexandra -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Convenient Access</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from Alexandra
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              From the Alexandra area, Patricia's studio in Tengah is approximately a 20-minute drive. The route follows Alexandra Road westward to join the AYE, which runs directly through to the Tengah area. Families near Queensway Shopping Centre, IKEA Alexandra, or the Dawson HDB estate will find the AYE entrance within a few minutes of their doorstep.
            </p>
            <p class="text-base-600 mb-4">
              The nearest MRT stations are Queenstown (East-West Line) and Labrador Park (Circle Line). From Queenstown, you can travel westward to Jurong East and connect to bus services towards Tengah. The public transport option is workable, though driving remains the most efficient choice for regular weekly lessons.
            </p>
            <p class="text-base-600">
              Patricia offers house visits for Alexandra families who prefer their child to learn at home. Whether you live in the condominiums along Alexandra Road, the Tanglin Halt flats, or the Dawson estate, Patricia will travel to you with all the materials needed for a complete lesson.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By car:</strong> About 20 minutes via Alexandra Road to the AYE westbound towards Tengah</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By MRT:</strong> Queenstown MRT (East-West Line) or Labrador Park MRT (Circle Line) with bus transfers westward</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By bus:</strong> Services from Alexandra Road towards Jurong and the western corridor</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">House visits:</strong> Available throughout Alexandra, Queensway, Tanglin Halt, and the Dawson estate</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- What Lessons Look Like -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Lesson Structure</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What Lessons Look Like
          </h2>
        </div>

        <div class="space-y-4 text-base-600">
          <p>
            Each violin lesson is a private, one-to-one session designed to meet your child where they are and move them forward at the right pace. Sessions run between 30 and 60 minutes, with Patricia recommending shorter durations for younger beginners and extending as the student's endurance and concentration mature.
          </p>
          <p>
            Patricia opens every lesson with a review of fundamentals — checking that posture remains correct, the bow hold is balanced, and the violin is sitting comfortably. She then works through technical exercises tailored to the student's current needs: smooth, even bowing across all strings; clean left-hand finger placement; scales in various keys and positions. Repertoire study follows, with Patricia guiding the student through their current pieces with attention to tone colour, phrasing, dynamic shaping, and rhythmic precision.
          </p>
          <p>
            Sight-reading practice and aural exercises are part of every session, building the comprehensive musicianship that supports both exam success and genuine musical enjoyment. ABRSM candidates receive targeted preparation across all examination components, while non-exam students progress through a thoughtfully sequenced programme of studies and performance pieces.
          </p>
        </div>

        <div class="text-center mt-8">
          <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            View Full Lesson Details
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in Alexandra:
          <a href="/piano-lessons-alexandra/" class="text-primary-600 hover:underline">Piano Lessons</a> ·
          <a href="/music-lessons-alexandra/" class="text-primary-600 hover:underline">Music Lessons</a> ·
          <a href="/abrsm-piano-lessons-alexandra/" class="text-primary-600 hover:underline">ABRSM Piano</a> ·
          <a href="/abrsm-violin-lessons-alexandra/" class="text-primary-600 hover:underline">ABRSM Violin</a> ·
          <a href="/music-theory-lessons-alexandra/" class="text-primary-600 hover:underline">Music Theory</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/violin-lessons-redhill/" class="text-primary-600 hover:underline">Redhill</a>,
          <a href="/violin-lessons-queenstown/" class="text-primary-600 hover:underline">Queenstown</a>, and
          <a href="/violin-lessons-telok-blangah/" class="text-primary-600 hover:underline">Telok Blangah</a>.
          <a href="/lessons/" class="text-primary-600 hover:underline">View all lesson details</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Start Your Child's Violin Journey
        </h2>
        <p class="text-base-600 mb-6">Get in touch with Patricia about violin lessons for your child in Alexandra. A free consultation is the perfect starting point — no obligation, just a friendly discussion about your child's musical interests.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20interested%20in%20violin%20lessons%20for%20my%20child%20in%20Alexandra."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>
