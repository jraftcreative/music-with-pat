---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'
---

<BaseLayout
  title="Piano Lessons for Children in Tengah & West Singapore | Music with Pat"
  description="Structured piano lessons for children ages 4+ in Tengah, Singapore. ABRSM preparation, sight-reading, aural training & music theory. Serving Jurong West, Bukit Batok, Bukit Timah & Choa Chu Kang."
>
  <Header currentPage="/lessons/" />
  <Breadcrumbs items={[{ label: 'Lessons' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">What We Offer</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          Piano Lessons for Children in Tengah, Singapore
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          Patricia's lessons are thoughtfully structured to nurture your child's musical growth — from first notes to ABRSM examinations and beyond. Conveniently located in Tengah, west Singapore.
        </p>
      </div>
    </section>

    <!-- Lesson Details -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex md:flex-row items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 mb-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z" /></svg>
              <div>
                <h2 class="text-lg font-semibold text-base-900 mb-2">Ages 4 and Up</h2>
                <p class="text-base-600 text-sm">Lessons are designed for young learners from age four, when musical foundations are most naturally absorbed. Complete beginners are always welcome.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex md:flex-row-reverse items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 mb-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
              <div>
                <h2 class="text-lg font-semibold text-base-900 mb-2">45–60 Minute Sessions</h2>
                <p class="text-base-600 text-sm">Each lesson covers both theory and practical work. Session length is tailored to your child's age and attention span.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex md:flex-row items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 mb-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
              <div>
                <h2 class="text-lg font-semibold text-base-900 mb-2">Home-Based Studio</h2>
                <p class="text-base-600 text-sm">Lessons take place in Patricia's calm, comfortable home studio in Tengah, Singapore. House visits are available for families in Jurong West, Bukit Batok, Bukit Timah, Choa Chu Kang, and surrounding areas.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex md:flex-row-reverse items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 mb-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0 1 16.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.023 6.023 0 0 1-2.77.896M7.73 9.728a6.023 6.023 0 0 0 2.77.896m0 0c.177.02.357.03.54.03.184 0 .363-.01.54-.03m-1.08 0a48.278 48.278 0 0 0 1.08 0m-1.08 0c.183 1.14.224 2.178.121 3.172m1.08-3.172a48.394 48.394 0 0 1-.12 3.172" /></svg>
              <div>
                <h2 class="text-lg font-semibold text-base-900 mb-2">ABRSM Preparation</h2>
                <p class="text-base-600 text-sm">Where appropriate, students are prepared for ABRSM graded examinations. Patricia guides each student through the syllabus at a comfortable pace.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What a Typical Lesson Looks Like -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Lesson Structure</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What a Typical Lesson Looks Like
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <span class="inline-flex items-center shrink-0 px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">5–10 min</span>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Warm-Up and Technique Exercises</h3>
                <p class="text-base-600 text-sm">Scales, finger exercises, and posture check to start focused.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <span class="inline-flex items-center shrink-0 px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">20–25 min</span>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Repertoire and Sight-Reading</h3>
                <p class="text-base-600 text-sm">Working through pieces, learning to read music fluently, and developing expression.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <span class="inline-flex items-center shrink-0 px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10–15 min</span>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Theory and Aural Training</h3>
                <p class="text-base-600 text-sm">Understanding musical concepts, ear training, and rhythm exercises.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <span class="inline-flex items-center shrink-0 px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">5 min</span>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Review and Practice Goals</h3>
                <p class="text-base-600 text-sm">Setting clear, achievable goals for home practice.</p>
              </div>
            </div>
          </div>
        </div>

        <p class="text-base-600 text-center mt-8 max-w-2xl mx-auto">
          Patricia adapts each lesson based on your child's energy and engagement level. Some days call for more creative exploration, while others are perfect for focused technique work.
        </p>
      </div>
    </section>

    <!-- Lessons by Age Group -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Tailored Approach</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Lessons by Age Group
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold mb-4">Ages 4–6</span>
            <h3 class="text-lg font-semibold text-base-900 mb-2">Early Starters</h3>
            <p class="text-base-600 text-sm mb-3">Fun musical activities, rhythm games, basic notation, short attention-friendly segments, no exam pressure.</p>
            <p class="text-base-600 text-sm">Tailored activities that feel like play while building real musical foundations.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold mb-4">Ages 7–9</span>
            <h3 class="text-lg font-semibold text-base-900 mb-2">Building Skills</h3>
            <p class="text-base-600 text-sm mb-3">ABRSM Grades 1–3 preparation, sight-reading development, theory fundamentals, building performance confidence.</p>
            <p class="text-base-600 text-sm">A structured approach that balances challenge with encouragement.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold mb-4">Ages 10–12</span>
            <h3 class="text-lg font-semibold text-base-900 mb-2">Growing Musicians</h3>
            <p class="text-base-600 text-sm mb-3">ABRSM Grades 3–5+, expressive playing, complex repertoire, developing musicality and interpretation.</p>
            <p class="text-base-600 text-sm">Students begin to develop their own musical identity.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Conveniently Located in Tengah -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Location</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Conveniently Located in Tengah
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <p class="text-base-600 mb-4">
              Patricia's home studio is located in Tengah Garden Town, Singapore's newest car-free HDB town. The quiet, family-friendly environment is ideal for focused learning without distractions.
            </p>
            <p class="text-base-600 mb-4">
              The studio is easily accessible from <a href="/piano-lessons-jurong-west/" class="text-primary-600 hover:underline">Jurong West</a>, <a href="/piano-lessons-bukit-batok/" class="text-primary-600 hover:underline">Bukit Batok</a>, <a href="/piano-lessons-bukit-timah/" class="text-primary-600 hover:underline">Bukit Timah</a>, <a href="/piano-lessons-choa-chu-kang/" class="text-primary-600 hover:underline">Choa Chu Kang</a>, and surrounding neighbourhoods in west Singapore. The future Jurong Region Line MRT will improve access further.
            </p>
            <p class="text-base-600">
              House visits are also available for families who prefer their child to learn at home. Contact Patricia to discuss arrangements.
            </p>
          </div>
          <div>
            <div class="bg-white rounded-xl p-6 border border-primary-100 mb-6">
              <h3 class="text-lg font-semibold text-base-900 mb-3">Nearby Areas We Serve</h3>
              <ul class="space-y-2 text-base-600 text-sm">
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <a href="/piano-lessons-jurong-west/" class="hover:text-primary-600 transition-colors">Jurong West</a>
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <a href="/piano-lessons-bukit-batok/" class="hover:text-primary-600 transition-colors">Bukit Batok</a>
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <a href="/piano-lessons-bukit-timah/" class="hover:text-primary-600 transition-colors">Bukit Timah</a>
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <a href="/piano-lessons-choa-chu-kang/" class="hover:text-primary-600 transition-colors">Choa Chu Kang</a>
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <a href="/piano-lessons-jurong-east/" class="hover:text-primary-600 transition-colors">Jurong East</a>
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <a href="/piano-lessons-clementi/" class="hover:text-primary-600 transition-colors">Clementi</a>
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <a href="/piano-lessons-bukit-panjang/" class="hover:text-primary-600 transition-colors">Bukit Panjang</a>
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <a href="/piano-lessons-yew-tee/" class="hover:text-primary-600 transition-colors">Yew Tee</a>
                </li>
              </ul>
            </div>
            <div class="bg-white rounded-xl p-6 border border-primary-100">
              <h3 class="text-lg font-semibold text-base-900 mb-3">Near These Schools</h3>
              <ul class="space-y-2 text-base-600 text-sm">
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  Jurong Primary School
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  Princess Elizabeth Primary School
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  Shuqun Primary School
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  St. Anthony's Primary School
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Teaching Philosophy Journey -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Teaching Philosophy</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Your Child's Musical Journey
          </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
          <div class="timeline-step text-center">
            <div class="w-10 h-10 rounded-full bg-primary-600 text-white flex items-center justify-center font-semibold mx-auto mb-3">1</div>
            <svg class="w-6 h-6 text-primary-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z" /></svg>
            <h3 class="text-sm md:text-base font-semibold text-base-900 mb-1">Foundation</h3>
            <p class="text-base-600 text-xs md:text-sm">Understanding key musical elements. Developing solid piano technique.</p>
          </div>
          <div class="timeline-step text-center">
            <div class="w-10 h-10 rounded-full bg-primary-600 text-white flex items-center justify-center font-semibold mx-auto mb-3">2</div>
            <svg class="w-6 h-6 text-primary-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
            <h3 class="text-sm md:text-base font-semibold text-base-900 mb-1">Development</h3>
            <p class="text-base-600 text-xs md:text-sm">Sight-reading. Aural training. Music theory. Practical piano playing.</p>
          </div>
          <div class="timeline-step text-center">
            <div class="w-10 h-10 rounded-full bg-primary-600 text-white flex items-center justify-center font-semibold mx-auto mb-3">3</div>
            <svg class="w-6 h-6 text-primary-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" /></svg>
            <h3 class="text-sm md:text-base font-semibold text-base-900 mb-1">Mastery</h3>
            <p class="text-base-600 text-xs md:text-sm">Curated repertoire to challenge and inspire. Developing musical expression. Performing confidently.</p>
          </div>
          <div class="timeline-step text-center">
            <div class="w-10 h-10 rounded-full bg-primary-600 text-white flex items-center justify-center font-semibold mx-auto mb-3">4</div>
