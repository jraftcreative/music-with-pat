---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "How do I get to the Tengah studio from Bukit Timah?",
    answer: "The studio is roughly an 18-minute drive from Bukit Timah. Head west via Bukit Timah Road or the PIE towards Tengah. The journey is straightforward and manageable as part of a weekly routine."
  },
  {
    question: "What instruments can my child learn with Patricia?",
    answer: "Patricia teaches piano, violin, and general musicianship. She can advise on the best starting point based on your child's age, interests, and personality. A free consultation is available to discuss options."
  },
  {
    question: "Does Patricia visit homes in Bukit Timah?",
    answer: "Yes, Patricia offers house visits throughout Bukit Timah, including along Dunearn Road, near the Nature Reserve, and across the established private estates. House visit rates differ slightly from studio sessions — contact Patricia for details."
  },
  {
    question: "How long before my child shows progress?",
    answer: "Most children show visible progress within the first month — improved coordination, growing confidence at the instrument, and an emerging sense of rhythm. Patricia sets realistic expectations and communicates progress regularly, so you always know how your child is developing."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="Music Lessons for Children in Bukit Timah | Music with Pat"
  description="Music lessons for children in Bukit Timah, Singapore. Piano, violin, and musicianship from an experienced educator. Studio in Tengah with house visits available. Ages 4 and up."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Music Lessons",
      "name": "Music Lessons for Children in Bukit Timah",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Bukit Timah, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "Piano, violin, and musicianship lessons for children in Bukit Timah, Singapore. Thoughtful teaching in a calm studio environment in nearby Tengah."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'Music Lessons Bukit Timah' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">Bukit Timah & Tengah</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          Music Lessons for Children in Bukit Timah
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          Bukit Timah is one of Singapore's most sought-after residential areas, where tree-lined roads, prestigious schools, and the Nature Reserve create an environment of quiet affluence. Families here invest carefully in their children's development, choosing quality over convenience. Patricia's studio in Tengah is about 18 minutes west, offering piano, violin, and musicianship lessons that combine serious expertise with the personal warmth that makes learning truly effective for children.
        </p>
      </div>
    </section>

    <!-- Why Families from Bukit Timah Choose Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why Families Trust Patricia</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Families from Bukit Timah Choose Patricia
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">A Complete Musical Offering</h3>
                <p class="text-base-600 text-sm">Patricia teaches piano, violin, and general musicianship — all with the same depth of expertise. Bukit Timah families appreciate not having to search for separate teachers. Whether your child already has a clear preference or is still discovering their musical interests, Patricia can guide them with informed, personal attention.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Child Development Expertise</h3>
                <p class="text-base-600 text-sm">Patricia's Bachelor's degree in Early Childhood Education with Music Education gives her teaching a depth that Bukit Timah families expect. She does not just teach music — she understands how children think, how they learn, and how to bring out their best. Every lesson is informed by this dual expertise.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Principled Approach to Exams</h3>
                <p class="text-base-600 text-sm">ABRSM preparation is available, but Patricia will never recommend it unless she genuinely believes it will benefit your child. She is straightforward about whether exams or a broader repertoire-based approach would serve your child better — the kind of honesty that Bukit Timah families value.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Intimate Studio Setting</h3>
                <p class="text-base-600 text-sm">Patricia's home studio in Tengah is private, quiet, and designed for focused learning. It is a contrast to the commercial music schools that dot Bukit Timah's shopping centres — here, children can concentrate fully, and Patricia gives each student her undivided attention.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from Bukit Timah -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Easy to Reach</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from Bukit Timah
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              From Bukit Timah, the drive to Patricia's Tengah studio takes approximately 18 minutes. The route heads west via Bukit Timah Road or the PIE, connecting to the Tengah area. Traffic is generally manageable outside peak hours.
            </p>
            <p class="text-base-600 mb-4">
              Some families schedule lessons on weekend mornings, making the drive a relaxed part of the week. Others combine the trip with visits to Jurong East or the growing amenities in the Tengah neighbourhood.
            </p>
            <p class="text-base-600">
              Patricia also provides house visits throughout Bukit Timah. Whether you live along Dunearn Road, near the Nature Reserve, or in one of the established private estates, she can bring lessons to your home.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By car:</strong> Around 18 minutes via Bukit Timah Road or the PIE</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By MRT:</strong> Downtown Line from Beauty World or King Albert Park to Bukit Panjang, then bus or drive to Tengah</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By bus:</strong> Bus services along Bukit Timah Road connect towards the western corridor</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">House visits:</strong> Available across Bukit Timah, including Dunearn Road, private estates, and surrounding areas</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- What Lessons Look Like -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Lesson Structure</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What Lessons Look Like
          </h2>
        </div>

        <div class="space-y-4 text-base-600">
          <p>
            Each lesson is a private, one-to-one session lasting 45 to 60 minutes. For younger children, Patricia starts with shorter sessions and extends them as concentration builds. Bukit Timah families appreciate this thoughtful calibration — it signals a teacher who prioritises the child's experience over a fixed schedule.
          </p>
          <p>
            Whether studying piano, violin, or general musicianship, sessions integrate practical playing with ear training, theory, and creative exploration. Patricia keeps lessons varied and purposeful, building genuine musical competence alongside a real love for the art.
          </p>
          <p>
            Lesson quality is identical whether your child visits the Tengah studio or Patricia comes to your Bukit Timah home. The teaching is always personal, focused, and adapted to your child's individual needs.
          </p>
        </div>

        <div class="text-center mt-8">
          <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            View Full Lesson Details
          </a>
        </div>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-piano-lessons.webp"
              alt="Patricia - Music Teacher for Children near Bukit Timah"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              Patricia has taught music to children for over a decade, building a practice that spans piano, violin, and musicianship. Based in Tengah, she serves families from Bukit Timah, Holland Village, and the broader western corridor. Her reputation has been built through genuine results and warm, lasting relationships with families.
            </p>
            <p class="text-base-600 mb-4">
              Her Bachelor's degree in Early Childhood Education with Music Education means she brings academic depth to every lesson. She understands developmental psychology, age-appropriate pedagogy, and the intersection of musical and cognitive development.
            </p>
            <p class="text-base-600 mb-6">
              Patricia is thoughtful and principled. She builds trust with her students while maintaining the high standards that Bukit Timah families expect. Whether your child is taking their first steps in music or preparing for advanced exams, she provides the same careful, individualised attention.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Preparation</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Ages 4+</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in Bukit Timah:
          <a href="/piano-lessons-bukit-timah/" class="text-primary-600 hover:underline">Piano Lessons</a> ·
          <a href="/violin-lessons-bukit-timah/" class="text-primary-600 hover:underline">Violin Lessons</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/music-lessons-beauty-world/" class="text-primary-600 hover:underline">Beauty World</a>,
          <a href="/music-lessons-king-albert-park/" class="text-primary-600 hover:underline">King Albert Park</a>, and
          <a href="/music-lessons-holland-village/" class="text-primary-600 hover:underline">Holland Village</a>.
          <a href="/lessons/" class="text-primary-600 hover:underline">View all lesson details</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Start Your Child's Musical Journey
        </h2>
        <p class="text-base-600 mb-6">Get in touch with Patricia for a free consultation to discuss your child's interests and what lessons could look like. No commitment needed.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20interested%20in%20music%20lessons%20for%20my%20child%20in%20Bukit%20Timah."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>