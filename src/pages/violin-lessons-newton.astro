---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "How long is the journey from Newton to Patricia's studio?",
    answer: "Patricia's studio in Tengah is approximately a 28-minute drive from Newton via the PIE heading west. Families using public transport can take the Downtown Line (DT11) or North-South Line (NS21) from Newton MRT and transfer towards Tengah. The commute is predictable and several Newton-area families already make the trip weekly."
  },
  {
    question: "What age is appropriate for a child to start violin?",
    answer: "Patricia accepts violin students from age 4. Young beginners use fractional-size violins — typically a 1/4 size for four- and five-year-olds, moving to 1/2 and 3/4 as they grow. At the first consultation, Patricia assesses your child's motor coordination, attention span, and enthusiasm for the instrument to determine whether they are ready or would benefit from waiting a little longer."
  },
  {
    question: "Can my child prepare for ABRSM violin exams with Patricia?",
    answer: "Yes. ABRSM violin preparation is built into the regular lesson programme. Patricia covers all required components — scales, arpeggios, performance pieces, sight-reading, and aural tests — as part of weekly sessions. She enters students for examinations only when they are genuinely prepared, which keeps the experience positive and reduces exam anxiety."
  },
  {
    question: "Does Patricia teach violin at homes in the Newton area?",
    answer: "Patricia teaches from her dedicated home studio in Tengah. The studio is set up specifically for one-to-one music instruction with young learners — the consistent environment, acoustics, and materials help children settle into a focused learning routine. House visits are not available at this time."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="Violin Lessons for Children in Newton | Music with Pat"
  description="Violin lessons for children near Newton, Singapore. Qualified early childhood music teacher with 10+ years experience. ABRSM violin preparation, fractional-size instruments for young beginners, and a nurturing approach. Studio ~28 min from Newton via PIE."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Violin Lessons",
      "name": "Violin Lessons for Children in Newton",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Newton, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "Nurturing violin lessons for children from the Newton area. Child-centred teaching, ABRSM preparation, and a structured curriculum tailored to each young violinist."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'Violin Lessons Newton' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">Newton</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          Violin Lessons for Children in Newton
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          Newton sits at the heart of central Singapore, where the Downtown Line and North-South Line intersect. Families in this well-connected neighbourhood have easy access to quality services across the island, and Patricia's Tengah violin studio is no exception — about 28 minutes by car via the PIE. She provides structured, individual violin lessons for children, built around patience, proper technique, and steady musical growth.
        </p>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-piano-lessons.webp"
              alt="Patricia - Violin Teacher for Children near Newton"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              Patricia has more than ten years of experience teaching music to children, starting with students as young as four. She holds a Bachelor's degree in Early Childhood Education with a specialisation in Music Education — a qualification that directly influences how she teaches violin. She knows that young children need carefully staged instruction, with each new physical and musical skill introduced when the child is developmentally ready for it.
            </p>
            <p class="text-base-600 mb-6">
              Her home studio in Tengah is a quiet, personal space designed for focused one-to-one tuition. Unlike commercial music centres, it offers privacy and calm — qualities that matter for violin, where active listening and precise physical control are required from the very first lesson. Parents from Newton, Novena, and the central region make the trip because they see real, measurable progress in their children and value the warmth and professionalism Patricia brings to every session.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Preparation</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Ages 4+</span>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Why Families Choose Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why Newton Parents Trust Us</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Families from Newton Choose Patricia
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Patient Teaching Style</h3>
                <p class="text-base-600 text-sm">The early stages of violin require a level of physical coordination that many children find challenging — holding the instrument, controlling the bow, and placing fingers accurately on unfretted strings all at once. Patricia takes a calm, methodical approach, helping each child master these skills at their own pace without pressure or frustration.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Early Childhood Training</h3>
                <p class="text-base-600 text-sm">Patricia holds a Bachelor's degree in Early Childhood Education with a specialisation in Music Education. This formal training means she understands the developmental stages children move through and adjusts her violin teaching accordingly — knowing, for example, when a child's fine motor skills are ready for shifting positions or more complex bowing patterns.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Structured Progression</h3>
                <p class="text-base-600 text-sm">Patricia's curriculum takes students from their first open-string sounds through to scales, position work, and ABRSM graded repertoire in a deliberate, well-planned sequence. Technique, theory, sight-reading, and ear training are all developed in parallel, so your child grows as a complete musician rather than advancing unevenly.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Personal Studio Environment</h3>
                <p class="text-base-600 text-sm">Patricia's Tengah studio is a personal, purpose-built teaching space — quiet, comfortable, and free from the distractions of a busy music school. For violin, where accurate intonation and tone quality demand careful listening, this focused environment makes a real difference to the quality of each lesson.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from Newton -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Location</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from Newton
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              Patricia's studio is in Tengah, the newest town in Singapore's western corridor. From the Newton area — Newton Circus, Bukit Timah Road, and the surrounding residential streets — the drive takes around 28 minutes via the Pan Island Expressway (PIE) heading west. The route connects to the Kranji Expressway (KJE) before exiting at Tengah.
            </p>
            <p class="text-base-600 mb-4">
              Newton MRT sits at the interchange of the Downtown Line (DT11) and the North-South Line (NS21), giving families multiple public transport options heading west. A transfer is needed to reach Tengah, but the overall journey is manageable. Many parents from central Singapore choose to drive or book a private hire car for convenience, particularly with a young child and instrument.
            </p>
            <p class="text-base-600">
              Families who make the trip regularly find that the routine becomes second nature. The dedicated travel time helps children mentally prepare for a focused, productive lesson.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <div>
                  <p class="font-medium text-base-900 text-sm">By Car</p>
                  <p class="text-base-600 text-sm">Approximately 28 minutes via PIE westbound. On-site parking is available at the Tengah studio.</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <div>
                  <p class="font-medium text-base-900 text-sm">By MRT</p>
                  <p class="text-base-600 text-sm">Downtown Line (DT11) or North-South Line (NS21) from Newton MRT, transferring westward towards Tengah.</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <div>
                  <p class="font-medium text-base-900 text-sm">By Private Hire</p>
                  <p class="text-base-600 text-sm">A Grab ride from Newton to Tengah typically takes about 28 minutes and is a comfortable option for families travelling with a child and violin.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What Lessons Look Like -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">The Experience</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What Lessons Look Like
          </h2>
        </div>

        <div class="max-w-3xl mx-auto">
          <p class="text-base-600 mb-4">
            Every violin lesson is private and individually planned around your child's level, learning style, and pace. Beginners work on the most important foundations first — standing naturally with the violin, holding and drawing the bow without tension, and listening closely to the tone they produce. Patricia is careful with these early habits because they shape how a child plays for years to come.
          </p>
          <p class="text-base-600 mb-4">
            As students gain confidence, lessons broaden to include left-hand finger placement, simple scales, sight-reading, and musical expression. Young children aged 4 to 6 use fractional-size violins (1/4, 1/2, or 3/4) selected for their arm length, which prevents the tension and poor habits that develop when a child plays on an instrument that is too large for their frame.
          </p>
          <p class="text-base-600 mb-6">
            Students preparing for ABRSM violin grades work through all required elements — scales and arpeggios, performance pieces, sight-reading, and aural tests — as part of their regular lessons. Patricia ensures that exam preparation builds naturally from week to week rather than becoming a source of last-minute stress.
          </p>
          <div class="text-center">
            <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
              See Full Lesson Details
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in Newton:
          <a href="/piano-lessons-newton/" class="text-primary-600 hover:underline">Piano Lessons</a> ·
          <a href="/music-lessons-newton/" class="text-primary-600 hover:underline">Music Lessons</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/violin-lessons-stevens/" class="text-primary-600 hover:underline">Stevens</a>,
          <a href="/violin-lessons-botanic-gardens/" class="text-primary-600 hover:underline">Botanic Gardens</a>, and
          <a href="/violin-lessons-bukit-panjang/" class="text-primary-600 hover:underline">Bukit Panjang</a>.
          <a href="/lessons/" class="text-primary-600 hover:underline">View all lesson details</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Start Your Child's Violin Journey
        </h2>
        <p class="text-base-600 mb-6">Book a free consultation with Patricia to discuss your child's musical goals and see if violin lessons are the right fit.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20interested%20in%20violin%20lessons%20for%20my%20child%20in%20Newton."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>
