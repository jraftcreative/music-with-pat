---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "What size violin does my child need to start with?",
    answer: "Patricia will assess your child's arm length and hand size during the initial consultation. Most children aged 4 to 5 start on a 1/8 or 1/4 size violin, while those aged 6 to 8 typically use a 1/2 size. Patricia can advise on where to rent or purchase a suitable fractional-size instrument in Singapore, so you don't need to have one before the first session."
  },
  {
    question: "How do I get from Bukit Batok to Patricia's studio in Tengah?",
    answer: "Bukit Batok is one of the closest neighbourhoods to Tengah. By car, the drive takes around 10 minutes via the PIE or Bukit Batok West Avenue. By public transport, you can take a bus from Bukit Batok MRT or Interchange towards the Tengah area. The upcoming Jurong Region Line will make rail access even more direct in the future."
  },
  {
    question: "Does Patricia follow a particular violin teaching method?",
    answer: "Patricia draws from both the Suzuki method and the ABRSM violin syllabus, depending on what suits each student. Younger children often benefit from Suzuki's listening-based approach in the early stages, while older students may move towards ABRSM graded examinations for structured progression. She tailors the blend to your child's temperament and goals."
  },
  {
    question: "Can my child switch from piano to violin, or learn both?",
    answer: "Absolutely. Some children who have been learning piano with Patricia decide to add violin, and vice versa. Having a foundation in one instrument often helps with the other — music reading skills and ear training carry across. Patricia can advise on scheduling if your child wants to pursue both."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="Violin Lessons for Children in Bukit Batok | Music with Pat"
  description="Violin lessons for children in Bukit Batok, Singapore. Patient teaching with fractional-size violins, ABRSM violin preparation, and proper bow technique from the start. Ages 4 and up."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Violin Lessons",
      "name": "Violin Lessons for Children in Bukit Batok",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Bukit Batok, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "Patient, child-centred violin lessons for children in Bukit Batok, Singapore. ABRSM violin preparation, fractional-size instruments, and a calm studio environment in nearby Tengah."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'Violin Lessons Bukit Batok' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">Bukit Batok & Tengah</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          Violin Lessons for Children in Bukit Batok
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          Bukit Batok is a well-established HDB town where families settle in for the long term. Patricia's violin studio in nearby Tengah is just a 10-minute drive away, offering a quiet, focused space where children from Bukit Batok can develop real violin skills — from learning to hold a fractional-size instrument correctly to building the bow control and posture habits that carry through to higher grades.
        </p>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-piano-lessons.webp"
              alt="Patricia - Violin Teacher for Children near Bukit Batok"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              Patricia has more than ten years of experience teaching music to children, with violin as a central part of her practice. Her studio in Tengah is a short drive from Bukit Batok, and she regularly works with families from the surrounding western neighbourhoods who want thoughtful, child-focused violin instruction.
            </p>
            <p class="text-base-600 mb-4">
              Her Bachelor's degree in Early Childhood Education with Music Education means she approaches violin teaching with an understanding of how children develop physically and cognitively. This matters for violin especially, where the physical demands on a young body require a teacher who truly understands age-appropriate expectations for posture, bow technique, and finger placement.
            </p>
            <p class="text-base-600 mb-6">
              Her teaching is attentive and encouraging, with a clear structure that gives students direction while leaving room for enjoyment. From the first open strings to more advanced bowing techniques, Patricia builds each student's skills with care and consistency.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Preparation</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Ages 4+</span>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Why Families from Bukit Batok Choose Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why Families Choose Patricia</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Families from Bukit Batok Choose Patricia
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Patience with Every Beginner</h3>
                <p class="text-base-600 text-sm">The violin demands coordination that takes time to develop — holding the bow, positioning the left hand, maintaining posture. Patricia never rushes this process. She gives each Bukit Batok child the space to build these foundational habits naturally, celebrating small victories along the way rather than pushing for speed.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Trained in Early Childhood Development</h3>
                <p class="text-base-600 text-sm">Patricia's Bachelor's degree in Early Childhood Education with Music Education gives her an edge that matters for violin teaching. She understands the physical and cognitive milestones that affect how a four- or five-year-old holds an instrument, processes feedback, and builds motor memory — knowledge that shapes every lesson she teaches.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">ABRSM Violin Pathway</h3>
                <p class="text-base-600 text-sm">For families who want a structured route, Patricia prepares students for ABRSM violin examinations — covering scales, arpeggios, set pieces, sight-reading, and aural tests. She uses the graded framework as a progression tool, entering children only when they are genuinely prepared and confident.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">A Studio Built for Focused Learning</h3>
                <p class="text-base-600 text-sm">Patricia's home studio in Tengah is a private, distraction-free space where your child can hear every nuance of their own tone. For violin students especially, this quiet environment makes a tangible difference — children develop better pitch awareness and a more refined ear than they would in a noisy group setting.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from Bukit Batok -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Convenient Access</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from Bukit Batok
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              Patricia's studio in Tengah sits just west of Bukit Batok, connected by the Pan Island Expressway and local roads through Bukit Batok West Avenue. For families living near Bukit Batok Central, West Mall, or the HDB blocks along Bukit Batok Street, the drive typically takes around 10 minutes.
            </p>
            <p class="text-base-600 mb-4">
              By public transport, buses from Bukit Batok Interchange run towards the Tengah and Jurong West area. The upcoming Tengah MRT station on the Jurong Region Line will shorten the journey further once it opens.
            </p>
            <p class="text-base-600">
              House visits are also available for families who prefer violin lessons at home. Patricia travels with all the materials needed, and for younger children still getting comfortable with their fractional-size instrument, the familiar home environment can ease the early learning process.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By car:</strong> About 10 minutes via PIE or Bukit Batok West Avenue towards Tengah</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By MRT:</strong> Bukit Batok MRT (North-South Line) with bus connections towards the Tengah area</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By bus:</strong> Services from Bukit Batok Interchange towards Jurong West and Tengah</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">House visits:</strong> Available throughout Bukit Batok and surrounding HDB estates</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- What Lessons Look Like -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Lesson Structure</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What Lessons Look Like
          </h2>
        </div>

        <div class="space-y-4 text-base-600">
          <p>
            Every violin lesson is a private, one-to-one session tailored to your child. Sessions run between 30 and 60 minutes depending on age and experience, with younger beginners starting at the shorter end and building up as their concentration develops.
          </p>
          <p>
            Patricia structures each lesson around the core skills of violin playing: holding the instrument and bow correctly, producing a clean and steady tone, learning scales and shifting positions, and working through graded or chosen repertoire. Sight-reading and ear training are woven in throughout, building musicianship alongside technique. Children starting on 1/4 or 1/2 size violins receive particular attention to posture and bow arm alignment, so that good habits form from the outset.
          </p>
          <p>
            For students preparing for ABRSM violin examinations, Patricia covers all required components — scales, pieces, sight-reading, and aural tests — with targeted practice strategies. Students not on the exam track still follow a structured programme that keeps them progressing steadily through well-chosen pieces and technical exercises.
          </p>
        </div>

        <div class="text-center mt-8">
          <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            View Full Lesson Details
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in Bukit Batok:
          <a href="/piano-lessons-bukit-batok/" class="text-primary-600 hover:underline">Piano Lessons</a> ·
          <a href="/music-lessons-bukit-batok/" class="text-primary-600 hover:underline">Music Lessons</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/violin-lessons-bukit-gombak/" class="text-primary-600 hover:underline">Bukit Gombak</a>,
          <a href="/violin-lessons-bukit-panjang/" class="text-primary-600 hover:underline">Bukit Panjang</a>, and
          <a href="/violin-lessons-hillview/" class="text-primary-600 hover:underline">Hillview</a>.
          <a href="/lessons/" class="text-primary-600 hover:underline">View all lesson details</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Start Your Child's Violin Journey
        </h2>
        <p class="text-base-600 mb-6">Get in touch with Patricia for a free consultation to discuss your child's interests and what violin lessons could look like. No commitment needed.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20interested%20in%20violin%20lessons%20for%20my%20child%20in%20Bukit%20Batok."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>