---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "How do I get from HarbourFront to Patricia's studio in Tengah?",
    answer: "The drive from HarbourFront to Tengah takes approximately 25 minutes via the AYE. Head west past Queenstown and Clementi — it is a direct expressway route with no complicated turns. Many HarbourFront families schedule lessons after school or on weekend mornings when traffic is lighter."
  },
  {
    question: "Can Patricia come to HarbourFront for house visits?",
    answer: "Patricia teaches primarily from her dedicated home studio in Tengah, which provides a focused and quiet learning environment. House visits to the HarbourFront area may be arranged subject to availability — please message Patricia on WhatsApp to discuss."
  },
  {
    question: "What age can children start piano lessons with Patricia?",
    answer: "Patricia accepts students from age 4. Her Bachelor of Education in Early Childhood with Music means she has specific training in working with very young children, understanding their attention spans, motor development, and how to keep them engaged musically without overwhelming them."
  },
  {
    question: "Is ABRSM preparation included in lessons?",
    answer: "Patricia offers thorough ABRSM preparation for students who want it, covering all components including practical pieces, scales, sight-reading, and aural skills. However, exams are completely optional. She is happy to teach students who prefer learning without the structure of graded assessments."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="Piano Lessons for Children in HarbourFront | Music with Pat"
  description="Piano lessons for children near HarbourFront, Singapore. Patricia's Tengah studio is 25 minutes via AYE. ABRSM preparation, child-centred teaching for ages 4+."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Piano Lessons",
      "name": "Piano Lessons for Children in HarbourFront",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "HarbourFront, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "Nurturing piano lessons for children near HarbourFront, Singapore. Child-centred teaching, ABRSM preparation, and a calm home studio environment in nearby Tengah."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'Piano Lessons HarbourFront' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">HarbourFront</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          Piano Lessons for Children in HarbourFront
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          HarbourFront sits at the southern tip of Singapore's mainland, anchored by VivoCity and the bustling HarbourFront MRT interchange where the Circle and North-East lines converge. It is a neighbourhood that blends waterfront living with urban convenience, and families here are well-served by Patricia's piano studio in Tengah — a 25-minute drive westward along the AYE, away from the commercial buzz and into a calm, dedicated learning space.
        </p>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-piano-lessons.webp"
              alt="Patricia - Piano Teacher for Children near HarbourFront"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              Patricia has been teaching piano to children in Singapore for over a decade. She holds a Bachelor of Education in Early Childhood with Music, which gives her an unusually strong foundation for working with young learners. She understands the developmental milestones that shape how children absorb information, develop motor skills, and respond to musical instruction.
            </p>
            <p class="text-base-600 mb-4">
              For HarbourFront families who are used to the convenience of having everything nearby, the 25-minute drive to her Tengah studio might seem like a consideration. But parents who make the trip consistently say the same thing: the quality of teaching and the calm environment make it well worth the journey. There is a noticeable difference between a private studio lesson and a group class at a shopping mall music school.
            </p>
            <p class="text-base-600 mb-6">
              Patricia keeps parents informed with regular updates and clear practice guidance, so you always know where your child stands and what they should be working on between lessons.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Preparation</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Ages 4+</span>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Why Families from HarbourFront Choose Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why HarbourFront Parents Trust Patricia</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Families from HarbourFront Choose Patricia
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Lessons Built Around Your Child</h3>
                <p class="text-base-600 text-sm">Patricia does not follow a fixed curriculum blindly. She observes how each child responds, what motivates them, and where they struggle, then adjusts her lesson plans accordingly. HarbourFront parents appreciate this attentive, responsive style of teaching.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Genuine Child Development Knowledge</h3>
                <p class="text-base-600 text-sm">Patricia's degree in Early Childhood Education is not a decorative credential. It shapes how she reads a child's readiness, manages attention spans, and introduces new concepts at the right developmental moment — skills that most piano teachers simply do not have.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Clear ABRSM Guidance</h3>
                <p class="text-base-600 text-sm">Patricia prepares students thoroughly for ABRSM examinations — all components, no shortcuts. But she is equally straightforward about whether your child is ready, and she will never register a student for an exam just to fill a schedule. Her honesty builds trust with parents.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Peaceful Studio Setting</h3>
                <p class="text-base-600 text-sm">If your child has taken lessons in a commercial music school — perhaps one of the centres near VivoCity — you will notice the difference immediately. Patricia's Tengah home studio is quiet, private, and free from the bustle of a shopping mall. It is a space designed for genuine concentration and learning.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from HarbourFront -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Easy to Reach</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from HarbourFront
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              From HarbourFront, join the AYE westbound — the drive to Patricia's Tengah studio takes approximately 25 minutes. You will pass through the Queenstown and Clementi stretches before reaching the newer Tengah developments. Families living in the condominiums along Telok Blangah Road or Keppel Bay find this route direct and hassle-free.
            </p>
            <p class="text-base-600 mb-4">
              By MRT, take the Circle Line from HarbourFront to Buona Vista, transfer to the East-West Line towards Jurong East, and connect towards the Tengah area. The North-East Line also connects HarbourFront to the wider network for families coming from different directions.
            </p>
            <p class="text-base-600">
              Many HarbourFront parents prefer off-peak lesson times to keep the drive relaxed. Patricia offers flexible scheduling across weekday afternoons and weekends to accommodate different family routines.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0H6.375m11.25-3V6.75a3 3 0 0 0-3-3H3.375a1.125 1.125 0 0 0-1.125 1.125v11.25" /></svg>
                <div>
                  <span class="font-medium text-base-900 text-sm">By Car (AYE)</span>
                  <p class="text-base-600 text-sm">Approximately 25 minutes via the AYE westbound from HarbourFront. A direct expressway route through the southern and western corridors.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                <div>
                  <span class="font-medium text-base-900 text-sm">By MRT (CCL/NEL)</span>
                  <p class="text-base-600 text-sm">HarbourFront MRT (Circle Line or North-East Line) to Buona Vista, transfer to East-West Line towards Jurong East, then connect to Tengah.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" /></svg>
                <div>
                  <span class="font-medium text-base-900 text-sm">By Bus</span>
                  <p class="text-base-600 text-sm">Bus services from Telok Blangah Road and the HarbourFront interchange connect westward through the Queenstown corridor.</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- What Lessons Look Like -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Lesson Structure</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What Lessons Look Like
          </h2>
        </div>

        <div class="grid md:grid-cols-4 gap-6 mb-8">
          <div class="bg-white rounded-xl p-6 border border-primary-100 text-center">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold mb-3">1</span>
            <h3 class="font-semibold text-base-900 mb-2">Warm-Up & Technique</h3>
            <p class="text-base-600 text-sm">Structured finger exercises, scales, and posture work to prepare the hands and settle the mind before the main lesson content begins.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100 text-center">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold mb-3">2</span>
            <h3 class="font-semibold text-base-900 mb-2">Repertoire Work</h3>
            <p class="text-base-600 text-sm">Concentrated work on current pieces — tackling difficult sections, developing expression and dynamics, and refining performance quality.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100 text-center">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold mb-3">3</span>
            <h3 class="font-semibold text-base-900 mb-2">Theory & Aural</h3>
            <p class="text-base-600 text-sm">Music theory, sight-reading challenges, and ear training exercises integrated seamlessly into the lesson to develop complete musicianship.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100 text-center">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold mb-3">4</span>
            <h3 class="font-semibold text-base-900 mb-2">Review & Goals</h3>
            <p class="text-base-600 text-sm">A focused wrap-up with specific practice assignments for the week, giving both parent and child a clear roadmap for home practice.</p>
          </div>
        </div>

        <div class="text-center">
          <p class="text-base-600 mb-4">Young beginners enjoy shorter sessions filled with creative activities and playful exercises. More advanced students dedicate greater time to structured repertoire and exam preparation. Every lesson is shaped to the individual child's stage and needs.</p>
          <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            View Full Lesson Details
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in HarbourFront:
          <a href="/violin-lessons-harbourfront/" class="text-primary-600 hover:underline">Violin Lessons</a> ·
          <a href="/music-lessons-harbourfront/" class="text-primary-600 hover:underline">Music Lessons</a> ·
          <a href="/abrsm-piano-lessons-harbourfront/" class="text-primary-600 hover:underline">ABRSM Piano</a> ·
          <a href="/abrsm-violin-lessons-harbourfront/" class="text-primary-600 hover:underline">ABRSM Violin</a> ·
          <a href="/music-theory-lessons-harbourfront/" class="text-primary-600 hover:underline">Music Theory</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/piano-lessons-telok-blangah/" class="text-primary-600 hover:underline">Telok Blangah</a>,
          <a href="/piano-lessons-sentosa-cove/" class="text-primary-600 hover:underline">Sentosa Cove</a>, and
          <a href="/piano-lessons-bukit-merah/" class="text-primary-600 hover:underline">Bukit Merah</a>.
          <a href="/lessons/" class="text-primary-600 hover:underline">View all lesson details</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Start Your Child's Piano Journey
        </h2>
        <p class="text-base-600 mb-6">Book a free consultation with Patricia to discuss your child's interests and goals. HarbourFront families are welcome to arrange a trial lesson or simply chat about what to expect.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20a%20parent%20from%20HarbourFront%20and%20I'm%20interested%20in%20piano%20lessons%20for%20my%20child."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>
