---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "Is music theory boring for children?",
    answer: "Patricia goes out of her way to make theory engaging. She uses rhythm games, listening exercises, and short composition tasks rather than endless worksheets. Children in Bukit Merah who come expecting dry textbook work are often surprised to find themselves actively clapping rhythms, identifying chords at the keyboard, and even writing their own simple melodies within the first few lessons."
  },
  {
    question: "How long does it take to prepare for ABRSM Grade 5 Theory?",
    answer: "Preparation typically takes between 6 and 12 months with regular weekly lessons. The exact timeline depends on how much foundational theory your child has picked up from practical lessons, their comfort with written work, and how consistently they revise between sessions. Patricia sets a realistic pace for each student and adjusts as needed."
  },
  {
    question: "Can my child take theory lessons online?",
    answer: "Yes, online theory sessions are available and work very well. Theory involves written exercises, notation reading, and analytical discussion — all of which translate smoothly to a screen-based format. For Bukit Merah families juggling tight schedules, online lessons can be a practical way to fit theory preparation into the week without an additional commute."
  },
  {
    question: "When should my child start learning music theory?",
    answer: "Basic theory concepts are introduced from the start of practical lessons — reading notes, understanding rhythms, and recognising key signatures are all forms of theory. Dedicated exam preparation usually begins when a student reaches around Grade 3 or 4 on their instrument, leaving comfortable lead time before Grade 5 Theory becomes a prerequisite for higher practical exams."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="Music Theory Lessons in Bukit Merah | Music with Pat"
  description="ABRSM music theory lessons for children in Bukit Merah, Singapore. Grades 1–5 theory preparation with an experienced educator. Studio in Tengah with online options available. Ages 4 and up."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Music Theory Lessons",
      "name": "Music Theory Lessons in Bukit Merah",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Bukit Merah, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "ABRSM music theory preparation for children in Bukit Merah, Singapore. Covering Grades 1 through 5 with engaging, interactive teaching methods at a dedicated studio in Tengah."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'Music Theory Lessons Bukit Merah' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">Bukit Merah & Tengah</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          Music Theory Lessons in Bukit Merah
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          Bukit Merah is a mature estate where families have long prioritised practical, well-rounded education for their children. Music theory is an essential part of that picture — it gives young pianists and violinists the knowledge to understand what they play, not just reproduce it. Patricia offers structured ABRSM theory preparation from Grades 1 through 5, taught in a way that connects directly to your child's instrument and makes the written side of music feel relevant and accessible.
        </p>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-piano-lessons.webp"
              alt="Patricia - Music Theory Teacher for Children near Bukit Merah"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              With over ten years of teaching experience, Patricia understands that theory can feel intimidating to children who would rather be playing their instrument. That is exactly why she has developed methods that keep theory grounded in real music — connecting written concepts to the pieces students are already learning.
            </p>
            <p class="text-base-600 mb-4">
              Her Bachelor's degree in Early Childhood Education with Music Education means she knows how to teach abstract ideas to young minds. She breaks down concepts like intervals, key signatures, and chord progressions into manageable steps, using the piano to demonstrate what these ideas sound like in practice.
            </p>
            <p class="text-base-600 mb-6">
              Families in Bukit Merah appreciate her straightforward communication and consistent approach. Patricia sets clear expectations, gives honest feedback on progress, and ensures parents always know where their child stands in the theory preparation timeline.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Preparation</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Ages 4+</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Learn Music Theory -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why Theory Matters</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Families in Bukit Merah Invest in Music Theory
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">ABRSM Requirement</h3>
                <p class="text-base-600 text-sm">Grade 5 Theory is mandatory before a student can sit for Grades 6, 7, or 8 practical exams. Rather than treating it as a last-minute hurdle, Patricia integrates theory gradually so students meet the requirement comfortably and on schedule, without any stressful cramming near exam time.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Deeper Musical Understanding</h3>
                <p class="text-base-600 text-sm">When children understand the logic behind what they play — why a piece is in a particular key, what makes a chord progression resolve, how rhythm patterns create momentum — their performances become more musical and more confident. Theory provides the intellectual backbone that supports expressive playing.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Stronger Sight-Reading</h3>
                <p class="text-base-600 text-sm">Sight-reading improves markedly when a student can instantly recognise key signatures, understand time signatures at a glance, and anticipate interval patterns. Theory knowledge acts as a shortcut — students decode unfamiliar notation faster because they understand the system behind it, not just individual symbols.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Foundation for Composition</h3>
                <p class="text-base-600 text-sm">Children who learn about chord progressions, phrase structure, and musical form often discover they can create their own music. Theory opens the door to composition and arranging — skills that extend far beyond passing an exam and give students a lifelong creative outlet.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from Bukit Merah -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Easy to Reach</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from Bukit Merah
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              Bukit Merah is centrally located and well-connected by public transport. The drive to Patricia's Tengah studio takes approximately 20 minutes via the AYE, making it a manageable trip even on weekday afternoons. Families near Redhill MRT have quick expressway access heading west.
            </p>
            <p class="text-base-600 mb-4">
              For theory-only sessions, many Bukit Merah families opt for online lessons. The written, analytical nature of theory work translates seamlessly to video calls, and students save the commute time for extra practice or homework. Patricia's online theory sessions follow the same structured curriculum as in-person lessons.
            </p>
            <p class="text-base-600">
              Whether your family lives near the Henderson Waves, along Jalan Bukit Merah, or in the HDB blocks surrounding Redhill MRT, Patricia can work with you to find the most convenient arrangement.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By car:</strong> Around 20 minutes via AYE from Bukit Merah</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By MRT:</strong> East-West Line from Redhill MRT towards Jurong East, then Jurong Region Line towards Tengah</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">Online:</strong> Theory lessons available via video call — a popular choice for Bukit Merah families</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- What Theory Lessons Cover -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Grade-by-Grade Breakdown</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What Theory Lessons Cover
          </h2>
        </div>

        <div class="space-y-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Grade 1</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Grade 2</span>
            </div>
            <h3 class="text-lg font-semibold text-base-900 mb-2">Foundations</h3>
            <p class="text-base-600 text-sm">
              The early grades establish essential literacy: reading and writing notes in treble and bass clefs, understanding note values and rests, working with time signatures such as 2/4, 3/4, and 4/4, and recognising key signatures with up to two sharps or flats. Students also learn musical terms, dynamics markings, and basic performance directions. Patricia ensures these building blocks are secure before moving forward.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Grade 3</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Grade 4</span>
            </div>
            <h3 class="text-lg font-semibold text-base-900 mb-2">Intermediate</h3>
            <p class="text-base-600 text-sm">
              Students move into compound time (6/8, 9/8, 12/8), explore all major and minor key signatures, and learn to identify and write intervals. Chord recognition begins with primary triads (I, IV, V), and transposition between closely related keys is introduced. The vocabulary of Italian musical terms expands considerably. Patricia links every new concept back to pieces the student already knows, making abstract ideas tangible.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Grade 5</span>
            </div>
            <h3 class="text-lg font-semibold text-base-900 mb-2">Advanced</h3>
            <p class="text-base-600 text-sm">
              Grade 5 brings together everything learned so far and adds significant new material: irregular time signatures (5/4, 7/8), the alto and tenor clefs, chord inversions and extended progressions, cadence identification (perfect, plagal, imperfect, interrupted), transposition involving concert pitch and transposing instruments, and short melodic composition. This grade demands consistent, focused study and is the prerequisite for all higher practical exams.
            </p>
          </div>
        </div>

        <div class="text-center mt-8">
          <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            View Full Lesson Details
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Music Theory FAQs
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in Bukit Merah:
          <a href="/piano-lessons-singapore/" class="text-primary-600 hover:underline">Piano Lessons</a> ·
          <a href="/violin-lessons-singapore/" class="text-primary-600 hover:underline">Violin Lessons</a> ·
          <a href="/music-lessons-singapore/" class="text-primary-600 hover:underline">Music Lessons</a> ·
          <a href="/abrsm-piano-lessons-singapore/" class="text-primary-600 hover:underline">ABRSM Piano</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/music-theory-lessons-redhill/" class="text-primary-600 hover:underline">Redhill</a>,
          <a href="/music-theory-lessons-tiong-bahru/" class="text-primary-600 hover:underline">Tiong Bahru</a>, and
          <a href="/music-theory-lessons-telok-blangah/" class="text-primary-600 hover:underline">Telok Blangah</a>.
          <a href="/lessons/" class="text-primary-600 hover:underline">View all lesson details</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Give Your Child a Complete Musical Education
        </h2>
        <p class="text-base-600 mb-6">Get in touch with Patricia to discuss music theory preparation for your child in Bukit Merah. Free consultation — no commitment needed.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20interested%20in%20music%20theory%20lessons%20for%20my%20child%20in%20Bukit%20Merah."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>
