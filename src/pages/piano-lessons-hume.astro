---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "How do I get to the studio from Hume?",
    answer: "From the Hume area, the drive to Patricia's studio in Tengah takes roughly 12 minutes via Upper Bukit Timah Road. By MRT, Hume station on the Downtown Line (opened in 2025) provides direct rail access, with connections towards Bukit Panjang and the Jurong Region Line for Tengah. The short distance makes weekly lessons easy to fit into your schedule."
  },
  {
    question: "Does Patricia offer house visits near Hume and the Rail Mall?",
    answer: "Yes, house visits are available throughout the Hume area, including the residential developments near Rail Mall and the Upper Bukit Timah corridor. This is a convenient choice for families with young children who learn better in their own environment. House visit rates differ slightly from studio rates — reach out to Patricia for details."
  },
  {
    question: "What should we expect in the first few months of lessons?",
    answer: "In the first few months, Patricia focuses on building a solid foundation — proper posture, hand position, basic rhythms, and simple melodies. She introduces sight-reading and ear training gradually. Progress varies by child, but most students are playing recognisable pieces within the first term. The initial consultation gives you a clear picture of what to expect."
  },
  {
    question: "Does Patricia teach during school holidays?",
    answer: "Yes, lessons continue during school holidays for families who wish to maintain momentum. Some families also choose to adjust their schedule or increase lesson frequency during breaks. Patricia is flexible and will work with you to find an arrangement that suits your family's plans."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="Piano Lessons for Children in Hume | Music with Pat"
  description="Piano lessons for children in Hume, Singapore. Patient, child-centred teaching from a qualified early childhood educator. Studio in nearby Tengah with ABRSM preparation. Ages 4+."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Piano Lessons",
      "name": "Piano Lessons for Children in Hume",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Hume, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "Patient, child-centred piano lessons for children in Hume, Singapore. ABRSM preparation and a calm studio environment in nearby Tengah."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'Piano Lessons Hume' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">Hume & Tengah</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          Piano Lessons for Children in Hume
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          Hume is a quietly growing residential area along Upper Bukit Timah, near the Rail Mall and the heritage tracks of the old railway corridor. With the opening of Hume MRT station in 2025, the neighbourhood has become better connected while retaining its peaceful, semi-rural character. Patricia's studio in Tengah is just a short trip from Hume, offering piano lessons shaped by genuine early childhood expertise and a commitment to teaching that respects each child as an individual.
        </p>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-piano-lessons.webp"
              alt="Patricia - Piano Teacher for Children near Hume"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              Patricia has been teaching children piano for over ten years. Her studio in Tengah is just minutes from the Hume neighbourhood, making her an accessible choice for families in the Upper Bukit Timah and Rail Corridor area. She works with children from across this part of western Singapore.
            </p>
            <p class="text-base-600 mb-4">
              Her Bachelor's degree in Early Childhood Education with Music Education underpins everything she does. It means she approaches each lesson with an understanding of how children think, feel, and learn — not just how to play piano. This dual expertise is what makes her teaching consistently effective and responsive to individual needs.
            </p>
            <p class="text-base-600 mb-6">
              Patricia's style is gentle but purposeful. She nurtures confidence while maintaining clear expectations, creating a learning environment where children feel safe to try, fail, and improve. Whether your child is a complete beginner or preparing for ABRSM exams, she brings the same depth of care and attention to every session.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Preparation</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Ages 4+</span>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Why Families from Hume Choose Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why Families Trust Patricia</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Families from Hume Choose Patricia
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Teaching That Fits Your Child</h3>
                <p class="text-base-600 text-sm">Patricia adapts her teaching to each child's individual rhythm. She pays attention to how your child engages — what lights them up, where they get stuck, and how they respond to different types of encouragement. This careful observation allows her to build a lesson experience that truly fits your child rather than asking your child to fit a fixed method.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Early Childhood Expertise</h3>
                <p class="text-base-600 text-sm">With a Bachelor's degree in Early Childhood Education with Music Education, Patricia brings a level of developmental understanding that goes well beyond standard piano teaching. She knows how to structure learning for young children in ways that are age-appropriate, engaging, and musically meaningful — informed by formal training, not trial and error.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Exams When They Make Sense</h3>
                <p class="text-base-600 text-sm">For children who respond well to clear goals, ABRSM exam preparation is available and thorough. Patricia is also experienced at nurturing students who grow best through repertoire-based learning without formal grading. She will always discuss the options with you openly and recommend the path that genuinely serves your child.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">A Focused Learning Space</h3>
                <p class="text-base-600 text-sm">Patricia's Tengah studio is a dedicated, distraction-free environment designed for focused music learning. For families from the quiet Hume neighbourhood, the studio's intimate atmosphere feels like a natural continuation of the calm, unhurried surroundings they value at home — a place where children can concentrate fully on their music.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from Hume -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Easy to Reach</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from Hume
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              Hume and Tengah are close neighbours in Singapore's western corridor. Driving takes around 12 minutes via Upper Bukit Timah Road, making it one of the quickest journeys to Patricia's studio from any location she serves.
            </p>
            <p class="text-base-600 mb-4">
              The Hume MRT station, which opened on the Downtown Line in 2025, has improved the area's rail connectivity significantly. From Hume, you can head towards Bukit Panjang and transfer to the Jurong Region Line for Tengah. For families near Rail Mall and the surrounding residential developments, both driving and MRT are practical options.
            </p>
            <p class="text-base-600">
              House visits are also available for families throughout the Hume area. Given the close proximity, both studio visits and home lessons are easy to accommodate — the choice comes down to whichever setting works better for your child and your family's schedule.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By car:</strong> Around 12 minutes via Upper Bukit Timah Road</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By MRT:</strong> Downtown Line from Hume, connecting towards Bukit Panjang and the Jurong Region Line</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By bus:</strong> Services along Upper Bukit Timah Road towards the Tengah area</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">House visits:</strong> Available across Hume, Rail Mall area, and Upper Bukit Timah</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- What Lessons Look Like -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Lesson Structure</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What Lessons Look Like
          </h2>
        </div>

        <div class="space-y-4 text-base-600">
          <p>
            Each lesson is a one-to-one session running 45 to 60 minutes. For younger beginners, Patricia starts with shorter sessions and extends them as the child grows more comfortable and focused. This measured approach means children build their attention and skills at a natural pace without feeling rushed.
          </p>
          <p>
            Sessions combine playing, sight-reading, ear training, and theory in a balanced, engaging format. Patricia keeps activities varied and watches closely for signs that a child needs a change of pace or a different kind of challenge. The framework is structured, but the delivery is responsive and personal.
          </p>
          <p>
            Families from Hume can visit the Tengah studio or arrange house visits — both are convenient given the short distance between the two areas. Patricia provides the same attentive, well-prepared teaching in either setting, so the choice is entirely a matter of preference and logistics.
          </p>
        </div>

        <div class="text-center mt-8">
          <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            View Full Lesson Details
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in Hume:
          <a href="/violin-lessons-hume/" class="text-primary-600 hover:underline">Violin Lessons</a> ·
          <a href="/music-lessons-hume/" class="text-primary-600 hover:underline">Music Lessons</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/piano-lessons-hillview/" class="text-primary-600 hover:underline">Hillview</a>,
          <a href="/piano-lessons-beauty-world/" class="text-primary-600 hover:underline">Beauty World</a>, and
          <a href="/piano-lessons-cashew/" class="text-primary-600 hover:underline">Cashew</a>.
          <a href="/lessons/" class="text-primary-600 hover:underline">View all lesson details</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Start Your Child's Piano Journey
        </h2>
        <p class="text-base-600 mb-6">Get in touch with Patricia for a free consultation to discuss your child's interests and what lessons could look like. No commitment needed.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20looking%20for%20piano%20lessons%20for%20my%20child%20in%20Hume."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>
