---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "What is a typical preparation timeline for each ABRSM piano grade?",
    answer: "Most students need 12 to 18 months of focused preparation for each grade, depending on their age, practice consistency, and how large the leap is from the previous level. Patricia plans each student's journey individually and will only recommend entering an exam when she is confident the child is well-prepared across all four components: pieces, scales, sight-reading, and aural."
  },
  {
    question: "Is Grade 5 Theory required before sitting for higher ABRSM practical exams?",
    answer: "Yes. ABRSM requires candidates to hold a Grade 5 Theory pass (or equivalent) before they can enter Grades 6, 7, or 8 practical exams. Patricia integrates theory into regular lessons from the earliest stages, so the knowledge accumulates naturally over time and students are well-prepared when they reach that threshold."
  },
  {
    question: "How early can my child begin ABRSM piano exams?",
    answer: "There is no official minimum age, and Patricia focuses on readiness rather than rushing. Some children are comfortable with the Prep Test by age five or six, while others are better served by waiting until seven or eight before attempting Grade 1. A free initial consultation allows Patricia to meet your child and make an honest recommendation."
  },
  {
    question: "When are ABRSM exams available in Singapore?",
    answer: "Practical exam sessions run approximately two to three times a year in Singapore, generally around March, June, and October/November. Theory exams are now offered online year-round. Patricia stays on top of registration windows and guides families on the best session for their child's readiness."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="ABRSM Piano Lessons in Alexandra | Music with Pat"
  description="ABRSM piano exam preparation for children in Alexandra, Singapore. Comprehensive grade-by-grade preparation from Prep Test to Grade 8 at Patricia's Tengah studio, 20 minutes from the Queensway and IKEA Alexandra area."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "ABRSM Piano Lessons",
      "name": "ABRSM Piano Lessons for Children in Alexandra",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Alexandra, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "ABRSM piano exam preparation for children in Alexandra, Singapore. Covering practical pieces, scales, sight-reading, aural tests, and music theory from Prep Test through Grade 8."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'ABRSM Piano Lessons Alexandra' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">Alexandra to Tengah</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          ABRSM Piano Lessons for Children in Alexandra
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          The Alexandra area straddles the boundary between Singapore's central and western districts, with Queensway Shopping Centre, IKEA Alexandra, and established residential pockets creating a neighbourhood that is both accessible and family-friendly. For parents here who value a structured, internationally recognised approach to piano education, Patricia offers thorough ABRSM exam preparation at her Tengah studio — approximately 20 minutes via the AYE.
        </p>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-piano-lessons.webp"
              alt="Patricia - ABRSM Piano Teacher for Children near Alexandra"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              Patricia has guided children through the ABRSM piano graded system for over ten years, building a track record of Merits and Distinctions that reflects the quality of her preparation. She approaches each grade as a comprehensive musical education, not merely a checklist of requirements to satisfy an examiner.
            </p>
            <p class="text-base-600 mb-4">
              Her Bachelor's degree in Early Childhood Education with Music Education gives her a significant edge over teachers with purely musical training. She understands how children develop cognitively and emotionally at different ages, which informs her lesson planning, her expectations, and her ability to maintain each student's motivation across the months of preparation a grade requires.
            </p>
            <p class="text-base-600 mb-6">
              Families near the Alexandra area find Patricia's practical, results-oriented approach reassuring. She is clear about what each child needs to work on, transparent about their progress, and committed to ensuring they enter every exam fully prepared.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Specialist</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Tengah Studio</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Patricia for ABRSM -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why Families Trust Patricia</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Alexandra Families Choose Patricia for ABRSM
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Structured Preparation</h3>
                <p class="text-base-600 text-sm">Patricia builds a clear preparation framework for every grade, distributing attention evenly across pieces, technical work, sight-reading, and aural training. This balanced approach means students develop as well-rounded musicians rather than being strong in one area while falling short in another — exactly what ABRSM examiners look for.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Theory Integration</h3>
                <p class="text-base-600 text-sm">Theory knowledge is developed alongside practical playing, not as a bolt-on extra. Patricia connects concepts like key signatures, intervals, and form to the music students are actually learning, making theory feel relevant and manageable. This proactive approach ensures the Grade 5 Theory requirement is met smoothly when the time comes.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Exam Confidence</h3>
                <p class="text-base-600 text-sm">Patricia systematically removes the unknowns that cause exam anxiety. Through timed mock exams, performance walkthroughs, and discussions about what happens in the exam room, children arrive on the day feeling prepared and composed. This confidence is reflected in their ability to perform at their best when it counts.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.05 4.575a1.575 1.575 0 1 0-3.15 0v3m3.15-3v-1.5a1.575 1.575 0 0 1 3.15 0v1.5m-3.15 0 .075 5.925m3.075.75V4.575m0 0a1.575 1.575 0 0 1 3.15 0V15M6.9 7.575a1.575 1.575 0 1 0-3.15 0v8.175a6.75 6.75 0 0 0 6.75 6.75h2.018a5.25 5.25 0 0 0 3.712-1.538l1.732-1.732a5.25 5.25 0 0 0 1.538-3.712l.003-2.024a.668.668 0 0 0-.668-.668 1.667 1.667 0 0 1-1.667-1.667V7.575a1.575 1.575 0 0 0-3.15 0" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Individual Pacing</h3>
                <p class="text-base-600 text-sm">Patricia matches the pace of instruction to each student's development. She observes how quickly a child absorbs new material, adjusts her expectations accordingly, and only enters them for exams when they are truly ready. This respectful, individualised approach produces stronger results and keeps children motivated throughout their ABRSM journey.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from Alexandra -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Easy to Reach</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from Alexandra
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              The Alexandra area enjoys direct access to the AYE via Alexandra Road, making the drive to Patricia's Tengah studio a straightforward 20-minute trip. Whether you are coming from near Queensway Shopping Centre, IKEA Alexandra, or the Anchorpoint end, expressway access is within minutes.
            </p>
            <p class="text-base-600 mb-4">
              Families from the Alexandra area often combine the lesson trip with errands on the western side of Singapore, making efficient use of their time. After-school sessions and Saturday morning slots are both convenient options.
            </p>
            <p class="text-base-600">
              Patricia also offers house visits to the Alexandra neighbourhood, covering the HDB blocks and condominiums along Alexandra Road, Tanglin Halt Road, and the Queensway area. Home lessons maintain the same structured format and quality as sessions at her Tengah studio.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By car:</strong> Around 20 minutes via Alexandra Road and the AYE westbound</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By MRT:</strong> Circle Line from Labrador Park or bus to Queenstown MRT (EWL), then towards Jurong East and transfer to the Jurong Region Line</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By bus:</strong> Services along Alexandra Road and Queensway connect towards the AYE corridor and western Singapore</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">House visits:</strong> Available across the Alexandra area, including Tanglin Halt, Queensway, and the Anchorpoint vicinity</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ABRSM Exam Preparation -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Lesson Focus</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What ABRSM Exam Preparation Looks Like
          </h2>
        </div>

        <div class="space-y-4 text-base-600">
          <p>
            ABRSM preparation lessons with Patricia run 45 to 60 minutes and follow a carefully considered structure. The session opens with technical exercises — the scales, arpeggios, and broken chords specified for the current grade — before moving into detailed work on the three exam pieces.
          </p>
          <p>
            Patricia approaches repertoire with genuine musicianship, helping students understand the character of each piece rather than simply playing the right notes. She discusses phrasing, dynamics, and stylistic context in terms children can grasp, building the kind of expressive playing that earns strong marks. Piece selection is tailored to each student's strengths and areas for growth.
          </p>
          <p>
            Sight-reading and aural training are standard features of every lesson. Patricia treats these as skills that develop best through brief, consistent practice rather than last-minute preparation. For students at Grade 4 and above, theory discussions are woven into the lesson — analysing the key of a piece, identifying intervals within the music, recognising cadences and form — connecting written theory to lived musical experience.
          </p>
        </div>

        <div class="text-center mt-8">
          <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            View Full Lesson Details
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            ABRSM Piano FAQs — Alexandra
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in Alexandra:
          <a href="/piano-lessons-alexandra/" class="text-primary-600 hover:underline">Piano Lessons</a> ·
          <a href="/violin-lessons-alexandra/" class="text-primary-600 hover:underline">Violin Lessons</a> ·
          <a href="/music-lessons-alexandra/" class="text-primary-600 hover:underline">Music Lessons</a> ·
          <a href="/music-theory-lessons-alexandra/" class="text-primary-600 hover:underline">Music Theory</a> ·
          <a href="/abrsm-violin-lessons-alexandra/" class="text-primary-600 hover:underline">ABRSM Violin</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/abrsm-piano-lessons-redhill/" class="text-primary-600 hover:underline">Redhill</a>,
          <a href="/abrsm-piano-lessons-tiong-bahru/" class="text-primary-600 hover:underline">Tiong Bahru</a>, and
          <a href="/abrsm-piano-lessons-telok-blangah/" class="text-primary-600 hover:underline">Telok Blangah</a>.
          <a href="/abrsm-piano-lessons-singapore/" class="text-primary-600 hover:underline">View all ABRSM piano lessons</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Build Your Child's ABRSM Piano Skills
        </h2>
        <p class="text-base-600 mb-6">Contact Patricia for a free consultation to discuss your child's current ability, ABRSM aspirations, and what structured preparation looks like.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20interested%20in%20ABRSM%20piano%20lessons%20for%20my%20child%20in%20Alexandra."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>
