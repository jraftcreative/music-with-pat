---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

const faqs = [
  {
    question: "How long does it take for a child to move through each ABRSM piano grade?",
    answer: "Typically 12 to 18 months per grade, though this can vary depending on the child's age, practice habits, and the gap in difficulty between consecutive levels. Patricia prefers to take the time needed to build genuine mastery rather than rushing students into exams before they are confident in every component."
  },
  {
    question: "Does my child need to pass Grade 5 Theory to continue with higher ABRSM grades?",
    answer: "Yes. ABRSM requires a Grade 5 Theory pass (or equivalent qualification) before students can enter for Grades 6, 7, or 8 practical exams. Patricia addresses this from the start by integrating theory into practical lessons, so students gradually accumulate the knowledge they need without having to prepare for theory as a separate, disconnected exam."
  },
  {
    question: "What is the right age for my child to start sitting ABRSM exams?",
    answer: "There is no set minimum age, and readiness varies significantly between children. Patricia has started students on the Prep Test as young as five, while others have begun Grade 1 at eight. She evaluates each child individually during a consultation and will only recommend an exam entry when she believes the child is genuinely prepared and will have a positive experience."
  },
  {
    question: "How do ABRSM exam registrations work in Singapore?",
    answer: "ABRSM practical exams run two to three times a year in Singapore, with sessions typically around March, June, and October/November. Online theory exams can be taken throughout the year. Patricia keeps on top of registration deadlines and will advise you on the ideal session for your child based on where they are in their preparation."
  }
]

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
}
---

<BaseLayout
  title="ABRSM Piano Lessons in Tiong Bahru | Music with Pat"
  description="ABRSM piano exam preparation for children in Tiong Bahru, Singapore. Structured grade-by-grade preparation from Prep Test to Grade 8 at Patricia's Tengah studio, 25 minutes from Tiong Bahru MRT."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "ABRSM Piano Lessons",
      "name": "ABRSM Piano Lessons for Children in Tiong Bahru",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://www.musicwithpat.com/#business",
        "name": "Music with Pat"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Tiong Bahru, Singapore"
      },
      "audience": {
        "@type": "PeopleAudience",
        "suggestedMinAge": 4
      },
      "description": "ABRSM piano exam preparation for children in Tiong Bahru, Singapore. Covering practical pieces, scales, sight-reading, aural tests, and music theory from Prep Test through Grade 8."
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </Fragment>

  <Header />
  <Breadcrumbs items={[{ label: 'ABRSM Piano Lessons Tiong Bahru' }]} />

  <main>
    <!-- Hero -->
    <section class="py-10 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-primary-600 font-medium mb-2">Tiong Bahru to Tengah</p>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4">
          ABRSM Piano Lessons for Children in Tiong Bahru
        </h1>
        <p class="text-base-600 text-lg md:text-xl max-w-2xl mx-auto">
          Tiong Bahru is Singapore's oldest public housing estate, a heritage neighbourhood known for its distinctive Art Deco walk-up flats, independent cafes, and a community that values craft and character. For families here who want their children to pursue ABRSM piano exams with a teacher who takes preparation seriously, Patricia's Tengah studio is around 25 minutes away — a short drive along the AYE that leads to focused, systematic exam preparation.
        </p>
      </div>
    </section>

    <!-- About Patricia -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="md:order-2">
            <img
              src="/patricia-piano-lessons.webp"
              alt="Patricia - ABRSM Piano Teacher for Children near Tiong Bahru"
              class="aspect-[4/5] object-cover object-top rounded-2xl w-full"
              loading="lazy"
            />
          </div>
          <div class="md:order-1">
            <p class="text-primary-600 font-medium mb-2">Meet the Teacher</p>
            <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-4">
              About Patricia
            </h2>
            <p class="text-base-600 mb-4">
              For over ten years, Patricia has helped children in Singapore navigate the ABRSM piano graded system with confidence and genuine musical understanding. Her students regularly earn Merits and Distinctions — results that speak to the depth of preparation she provides, not just in the weeks before an exam but throughout the entire learning journey.
            </p>
            <p class="text-base-600 mb-4">
              Patricia's Bachelor's degree in Early Childhood Education with Music Education gives her a unique perspective that resonates with Tiong Bahru families. She does not simply drill scales and pieces — she understands how young minds learn, what motivates them, and how to build the kind of discipline that sustains long-term musical progress without turning practice into a chore.
            </p>
            <p class="text-base-600 mb-6">
              Her teaching philosophy mirrors the thoughtfulness that Tiong Bahru residents value: careful attention to detail, respect for the process, and a refusal to cut corners. Every lesson is tailored to the individual child, and every exam entry is timed to match genuine readiness.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">B.Ed Early Childhood & Music</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">10+ Years Experience</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">ABRSM Specialist</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-100 text-primary-700 text-xs font-semibold">Tengah Studio</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Patricia for ABRSM -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Why Families Trust Patricia</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Why Tiong Bahru Families Choose Patricia for ABRSM
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Structured Preparation</h3>
                <p class="text-base-600 text-sm">Patricia approaches ABRSM preparation with the same care that goes into any craft done well. Each grade is mapped out methodically — technical requirements, repertoire, sight-reading, and aural work all receive sustained attention across the preparation period, so nothing is overlooked or left until the final weeks.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Theory Integration</h3>
                <p class="text-base-600 text-sm">Patricia treats theory as an essential thread running through every lesson, not a separate subject to be crammed before an exam. Students learn to recognise keys, understand time signatures, and identify intervals through their playing, so when the Grade 5 Theory requirement arrives, they already possess the knowledge they need.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Exam Confidence</h3>
                <p class="text-base-600 text-sm">An exam should be a chance to demonstrate what a student has learnt, not a source of anxiety. Patricia rehearses the exam experience with mock sessions and timed performances so children feel prepared for the format, the pacing, and the interaction with the examiner. This familiarity translates directly into calmer, more assured performances.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 text-primary-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.05 4.575a1.575 1.575 0 1 0-3.15 0v3m3.15-3v-1.5a1.575 1.575 0 0 1 3.15 0v1.5m-3.15 0 .075 5.925m3.075.75V4.575m0 0a1.575 1.575 0 0 1 3.15 0V15M6.9 7.575a1.575 1.575 0 1 0-3.15 0v8.175a6.75 6.75 0 0 0 6.75 6.75h2.018a5.25 5.25 0 0 0 3.712-1.538l1.732-1.732a5.25 5.25 0 0 0 1.538-3.712l.003-2.024a.668.668 0 0 0-.668-.668 1.667 1.667 0 0 1-1.667-1.667V7.575a1.575 1.575 0 0 0-3.15 0" /></svg>
              <div>
                <h3 class="text-lg font-semibold text-base-900 mb-2">Individual Pacing</h3>
                <p class="text-base-600 text-sm">Patricia follows each student's natural learning curve. A child who connects deeply with a particular piece and needs more time to perfect it will receive that space, while a student who is excelling will be gently stretched towards the next level. Progress is always driven by ability and readiness, never by a fixed calendar.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Here from Tiong Bahru -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Easy to Reach</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            Getting Here from Tiong Bahru
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div>
            <p class="text-base-600 mb-4">
              Tiong Bahru is well-connected by the East-West MRT Line, with Tiong Bahru station providing easy access to the wider rail network. The drive from Tiong Bahru to Patricia's Tengah studio takes approximately 25 minutes via the AYE, a straightforward route that families quickly become familiar with.
            </p>
            <p class="text-base-600 mb-4">
              From the heritage area around Seng Poh Road and Yong Siak Street, the AYE is accessible via Tiong Bahru Road or Lower Delta Road. Weekend morning lessons are a popular choice for Tiong Bahru families who appreciate the quieter traffic on Saturday mornings.
            </p>
            <p class="text-base-600">
              For families who prefer home-based lessons, Patricia visits the Tiong Bahru neighbourhood, including the walk-up flats in the conservation area, the HDB blocks along Kim Tian Road, and the residential streets towards Havelock Road. Home lessons follow the same structured format as studio sessions.
            </p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-primary-100">
            <h3 class="text-lg font-semibold text-base-900 mb-4">Transport Options</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By car:</strong> Around 25 minutes via Tiong Bahru Road and the AYE westbound</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By MRT:</strong> East-West Line from Tiong Bahru to Jurong East, then transfer to the Jurong Region Line towards Tengah</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">By bus:</strong> Services from Tiong Bahru Road and Lower Delta Road connect towards the AYE corridor</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span class="text-base-600 text-sm"><strong class="text-base-900">House visits:</strong> Available throughout Tiong Bahru, including the conservation area, Kim Tian Road, and towards Havelock Road</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ABRSM Exam Preparation -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-primary-50">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Lesson Focus</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            What ABRSM Exam Preparation Looks Like
          </h2>
        </div>

        <div class="space-y-4 text-base-600">
          <p>
            Every ABRSM preparation lesson with Patricia is a one-to-one session of 45 to 60 minutes, structured to give each exam component the attention it deserves. Technical exercises open the lesson — scales, arpeggios, and broken chords appropriate to the current grade — building the physical fluency that underpins confident performance.
          </p>
          <p>
            Repertoire preparation takes centre stage, with Patricia guiding students through three contrasting pieces. She helps them discover what each piece is trying to express, teaching them to shape phrases musically, use dynamics purposefully, and bring character to their playing. Her piece selections balance the student's existing strengths with areas that need development.
          </p>
          <p>
            Each session closes with sight-reading and aural work. These are the components where marks are most commonly lost, and Patricia prevents that by building these skills gradually through regular, focused exercises. For students at intermediate levels and above, theory concepts are discussed in the context of the music being played, reinforcing practical understanding of notation, keys, and musical structure.
          </p>
        </div>

        <div class="text-center mt-8">
          <a href="/lessons/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            View Full Lesson Details
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-12 md:py-24 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-primary-600 font-medium mb-2">Common Questions</p>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900">
            ABRSM Piano FAQs — Tiong Bahru
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map(faq => (
            <details class="group bg-primary-50 rounded-xl">
              <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
                <span class="font-medium text-base-900 text-sm md:text-base pr-4">{faq.question}</span>
                <span class="text-primary-600 group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
              </summary>
              <div class="px-4 pb-4 text-base-600 text-sm">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Also Available -->
    <section class="py-6 px-6 md:px-12 bg-white">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also available in Tiong Bahru:
          <a href="/piano-lessons-tiong-bahru/" class="text-primary-600 hover:underline">Piano Lessons</a> ·
          <a href="/violin-lessons-tiong-bahru/" class="text-primary-600 hover:underline">Violin Lessons</a> ·
          <a href="/music-lessons-tiong-bahru/" class="text-primary-600 hover:underline">Music Lessons</a> ·
          <a href="/music-theory-lessons-tiong-bahru/" class="text-primary-600 hover:underline">Music Theory</a> ·
          <a href="/abrsm-violin-lessons-tiong-bahru/" class="text-primary-600 hover:underline">ABRSM Violin</a>
        </p>
      </div>
    </section>

    <!-- Also Serving Nearby -->
    <section class="py-8 px-6 md:px-12 bg-primary-50">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-base-600 text-sm">
          Also serving families in
          <a href="/abrsm-piano-lessons-redhill/" class="text-primary-600 hover:underline">Redhill</a>,
          <a href="/abrsm-piano-lessons-bukit-merah/" class="text-primary-600 hover:underline">Bukit Merah</a>, and
          <a href="/abrsm-piano-lessons-alexandra/" class="text-primary-600 hover:underline">Alexandra</a>.
          <a href="/abrsm-piano-lessons-singapore/" class="text-primary-600 hover:underline">View all ABRSM piano lessons</a>.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-white border-t border-primary-100">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-serif font-semibold text-base-900 mb-3">
          Set Your Child on the ABRSM Path
        </h2>
        <p class="text-base-600 mb-6">Get in touch with Patricia for a free consultation to discuss your child's musical interests, current level, and how ABRSM preparation would work for them.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="/contact/" class="inline-block px-8 py-4 bg-primary-600 text-white font-medium rounded-full hover:bg-primary-700 transition-colors">
            Book a Consultation
          </a>
          <a
            href="https://wa.me/6583898853?text=Hi%20Pat!%20I'm%20interested%20in%20ABRSM%20piano%20lessons%20for%20my%20child%20in%20Tiong%20Bahru."
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-green-500 text-white font-medium rounded-full hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>
