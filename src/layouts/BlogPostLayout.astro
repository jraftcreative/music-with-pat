---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import BottomNav from '../components/BottomNav.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

interface Props {
  title: string
  description: string
  pubDate: Date
  slug: string
}

const { title, description, pubDate, slug } = Astro.props
const siteUrl = 'https://www.musicwithpat.com'

const formattedDate = pubDate.toLocaleDateString('en-SG', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const isoDate = pubDate.toISOString()

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": isoDate,
  "dateModified": isoDate,
  "author": {
    "@type": "Person",
    "name": "Patricia",
    "url": `${siteUrl}/about/`
  },
  "publisher": {
    "@type": "Organization",
    "name": "Music with Pat",
    "url": siteUrl,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/music-with-pat-logo.png`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/blog/${slug}/`
  }
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl + "/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": siteUrl + "/blog/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title
    }
  ]
}
---

<BaseLayout
  title={`${title} | Music with Pat`}
  description={description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header currentPage="/blog/" />
  <Breadcrumbs items={[{ label: 'Blog', href: '/blog/' }, { label: title }]} />

  <main>
    <article class="py-12 md:py-20 px-6 md:px-12 bg-white">
      <div class="max-w-3xl mx-auto">
        <header class="mb-10">
          <h1 class="text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-base-900 mb-4 leading-tight">
            {title}
          </h1>
          <time datetime={isoDate} class="text-base-500 text-sm">
            {formattedDate}
          </time>
        </header>

        <div class="prose prose-base max-w-none
          prose-headings:font-serif prose-headings:text-base-900 prose-headings:font-semibold
          prose-h2:text-xl prose-h2:md:text-2xl prose-h2:mt-10 prose-h2:mb-4
          prose-h3:text-lg prose-h3:md:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-base-700 prose-p:leading-relaxed prose-p:mb-4
          prose-a:text-primary-600 prose-a:underline prose-a:underline-offset-2 hover:prose-a:text-primary-700
          prose-strong:text-base-800 prose-strong:font-semibold
          prose-ul:text-base-700 prose-ul:space-y-2 prose-ul:my-4
          prose-ol:text-base-700 prose-ol:space-y-2 prose-ol:my-4
          prose-li:leading-relaxed
          prose-table:my-6 prose-table:w-full
          prose-th:bg-primary-50 prose-th:text-left prose-th:px-4 prose-th:py-3 prose-th:text-base-800 prose-th:font-semibold prose-th:text-sm
          prose-td:px-4 prose-td:py-3 prose-td:text-base-700 prose-td:text-sm prose-td:border-b prose-td:border-primary-100
        ">
          <slot />
        </div>
      </div>
    </article>
  </main>

  <Footer />
  <BottomNav />
  <WhatsAppButton />
</BaseLayout>
